# ---------------------------------------------------------------------------
# Cross-machine inbox persistence (~/.claustrum/inbox/<uid>.json) + resume note
# ---------------------------------------------------------------------------

def _inbox_path(uid):
    return Path.home() / ".claustrum" / "inbox" / f"{uid}.json"


def _persist_inbox(uid, messages):
    """Append drained messages to ~/.claustrum/inbox/<uid>.json, de-duped by id.
    Best-effort — a write failure never propagates (callers are hooks)."""
    if not messages:
        return
    try:
        path = _inbox_path(uid)
        path.parent.mkdir(parents=True, exist_ok=True)
        existing = []
        if path.exists():
            try:
                existing = json.loads(path.read_text()) or []
            except Exception:
                existing = []
        seen = {m.get("id") for m in existing if isinstance(m, dict)}
        for m in messages:
            if m.get("id") not in seen:
                existing.append(m)
        path.write_text(json.dumps(existing, indent=2, default=str))
    except Exception:
        pass


def _format_resume(resume):
    """One-line human summary of a /v1/resume_check payload, or '' if nothing
    notable changed since the session was last seen."""
    if not isinstance(resume, dict):
        return ""
    since = resume.get("since_last_seen") or {}
    bits = []
    peers = since.get("peer_activity") or []
    if peers:
        bits.append(f"{len(peers)} peer(s) active in your repo/topic")
    prs = since.get("merged_prs") or []
    if prs:
        bits.append(f"{len(prs)} PR(s) finished")
    expired = since.get("expired_claims") or 0
    if expired:
        bits.append(f"{expired} of your file claim(s) expired")
    if not bits:
        return ""
    paused = resume.get("paused_for_seconds")
    prefix = ""
    if isinstance(paused, (int, float)) and paused > 300:
        prefix = f"Resumed after {_format_ago(paused)}. "
    return prefix + "Since last seen: " + "; ".join(bits) + "."


# ---------------------------------------------------------------------------
# Detail-layer derivation — repo-relative paths + git/gh metadata
#
# The cloud dedup engine intersects files_touched as a SET across machines, so
# paths MUST be repo-relative (two people on the same file have identical rel
# paths but different absolute ones). pr_number/last_push_at let the server
# bucket peers into the t2 "same PR" tier.
# ---------------------------------------------------------------------------

def _rel_to_repo(filepath, cwd=None):
    """Return `filepath` relative to its git toplevel, for cross-machine set
    overlap. Falls back to the basename if the file isn't inside a repo."""
    if not filepath:
        return None
    target = os.path.dirname(filepath) or (cwd or os.getcwd())
    try:
        result = subprocess.run(
            ["git", "-C", target, "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=1,
        )
        if result.returncode == 0:
            top = result.stdout.strip()
            if top:
                try:
                    return os.path.relpath(os.path.abspath(filepath), top)
                except ValueError:
                    pass
    except Exception:
        pass
    return os.path.basename(filepath)


def _git_last_push_at(target):
    """Best-effort ISO timestamp approximating the last push: commit date of the
    upstream-tracked HEAD (@{push}), falling back to HEAD's commit date. Local
    and fast — no network."""
    target = target or os.getcwd()
    for ref in ("@{push}", "HEAD"):
        try:
            result = subprocess.run(
                ["git", "-C", target, "log", "-1", "--format=%cI", ref],
                capture_output=True, text=True, timeout=1,
            )
            if result.returncode == 0 and result.stdout.strip():
                return result.stdout.strip()
        except Exception:
            pass
    return None


_PR_CACHE_PATH = DB_DIR / "pr-cache.json"
_PR_CACHE_TTL = 300  # seconds — re-query gh at most once per 5 min per branch


def _get_pr_number(target, repo, branch):
    """Best-effort current-branch PR number via `gh`, cached per (repo, branch)
    with a TTL so it isn't re-queried on every edit. Caches negative results
    too (a branch with no PR shouldn't trigger a gh call every keystroke).
    Returns int or None."""
    if not repo or not branch:
        return None
    key = f"{repo}:{branch}"
    now = time.time()

    cache = {}
    try:
        if _PR_CACHE_PATH.exists():
            cache = json.loads(_PR_CACHE_PATH.read_text())
    except Exception:
        cache = {}

    entry = cache.get(key)
    if isinstance(entry, dict) and (now - entry.get("ts", 0)) < _PR_CACHE_TTL:
        return entry.get("pr")

    pr = None
    try:
        result = subprocess.run(
            ["gh", "pr", "view", "--json", "number", "-q", ".number"],
            cwd=target or os.getcwd(),
            capture_output=True, text=True, timeout=3,
        )
        if result.returncode == 0 and result.stdout.strip().isdigit():
            pr = int(result.stdout.strip())
    except Exception:
        pr = None

    cache[key] = {"pr": pr, "ts": now}
    try:
        DB_DIR.mkdir(parents=True, exist_ok=True)
        _PR_CACHE_PATH.write_text(json.dumps(cache))
    except Exception:
        pass
    return pr


# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

def get_db():
    """Get a database connection with WAL mode and schema initialized."""
    DB_DIR.mkdir(parents=True, exist_ok=True)
    db = sqlite3.connect(str(DB_PATH), timeout=5)
    db.row_factory = sqlite3.Row
    db.execute("PRAGMA journal_mode=WAL")
    db.execute("PRAGMA busy_timeout=5000")
    _init_schema(db)
    return db


def _init_schema(db):
    db.executescript("""
        CREATE TABLE IF NOT EXISTS sessions (
            uid          TEXT PRIMARY KEY,
            label        TEXT,
            task         TEXT,
            working_on   TEXT,
            status       TEXT DEFAULT 'active',
            cwd          TEXT,
            last_seen    REAL NOT NULL,
            started_at   REAL NOT NULL,
            -- Liveness fields (process/tmux ground truth, not just the timer).
            -- host: only same-host sessions are tmux/boot-reaped; others fall
            --       back to the last_seen timer (cloud owns cross-machine).
            -- tmux_pane: e.g. '%28' — matched against `tmux list-panes -a`.
            -- pid: claude process pid — os.kill(pid,0) fallback when no pane.
            -- boot_id: machine boot epoch — a session from a previous boot is
            --          unambiguously dead (kills PID-reuse-after-reboot).
            host         TEXT,
            tmux_pane    TEXT,
            pid          INTEGER,
            boot_id      TEXT
        );

        CREATE TABLE IF NOT EXISTS messages (
            id           INTEGER PRIMARY KEY AUTOINCREMENT,
            from_uid     TEXT,
            to_uid       TEXT,
            type         TEXT NOT NULL DEFAULT 'info',
            body         TEXT NOT NULL,
            created_at   REAL NOT NULL,
            read_at      REAL
        );

        CREATE TABLE IF NOT EXISTS claims (
            filepath     TEXT NOT NULL,
            uid          TEXT NOT NULL,
            claimed_at   REAL NOT NULL,
            PRIMARY KEY (filepath, uid)
        );

        CREATE INDEX IF NOT EXISTS idx_messages_to
            ON messages(to_uid, read_at);
        CREATE INDEX IF NOT EXISTS idx_claims_file
            ON claims(filepath);
        CREATE INDEX IF NOT EXISTS idx_sessions_status
            ON sessions(status);
    """)
    # Migrate older DBs: add liveness columns if missing. Existing rows get
    # NULLs and fall back to the timer until their next heartbeat repopulates
    # them, so the upgrade is non-breaking.
    #
    # topic / topic_confidence mirror the cloud's emergent taxonomy down to the
    # local DB so a session's subject is joinable OFFLINE by uid (the cloud had
    # these from day one; locally they were missing). Populated two ways:
    #   - at classify time (cmd_classify_self writes here, authoritative), and
    #   - mirrored down from the cloud checkin response when already tagged.
    # Confidence is 0-100; heuristic auto-picks score low, deliberate picks 80.
    #
    # classify_prompted: set once we've injected the classify directive for an
    # untagged session. Guards against re-injecting it every turn — an untagged
    # session costs ONE line ever, then goes quiet (vs the old behaviour of
    # re-dumping the whole taxonomy into main context each turn).
    #
    # turn_count / turns_since_classify / drift_prompted are LOCAL-ONLY counters
    # (never sent to the cloud): turn_count gates the classify directive to turn
    # >= CLASSIFY_MIN_TURN; turns_since_classify drives the post-classification
    # drift cadence; drift_prompted caps drift re-surfaces. cmd_classify_self
    # resets the latter two when a (re)classification lands.
    existing = {r["name"] for r in db.execute("PRAGMA table_info(sessions)")}
    for col, decl in (
        ("host", "TEXT"),
        ("tmux_pane", "TEXT"),
        ("pid", "INTEGER"),
        ("boot_id", "TEXT"),
        ("topic", "TEXT"),
        ("topic_confidence", "INTEGER"),
        ("domain", "TEXT"),
        ("classify_prompted", "INTEGER DEFAULT 0"),
        ("turn_count", "INTEGER DEFAULT 0"),
        ("turns_since_classify", "INTEGER DEFAULT 0"),
        ("drift_prompted", "INTEGER DEFAULT 0"),
        # transcript_path: the Claude Code session JSONL (full chat), captured from
        # the hook payload, so the headless backstop can classify from real context
        # instead of the 200-char task. backstop_done: fired-once guard for it.
        ("transcript_path", "TEXT"),
        ("backstop_done", "INTEGER DEFAULT 0"),
        # private: 1 when the session ran under CLAUSTRUM_PRIVATE (never cloud-
        # published). Recorded locally so the footer can render the 🔒 glyph AND
        # so the machine-level heartbeat — which has no CLAUSTRUM_PRIVATE in its
        # own env — knows to SKIP cloud-pushing these rows (else a private session
        # leaks onto the board via the 60s tick). Set at registration from the
        # session's env; never written by the heartbeat (wrong env there).
        ("private", "INTEGER DEFAULT 0"),
    ):
        if col not in existing:
            db.execute(f"ALTER TABLE sessions ADD COLUMN {col} {decl}")
    db.commit()


# ---------------------------------------------------------------------------
# Liveness — derive "is this session actually alive right now?" from the OS /
# tmux, not from a heartbeat timer. A timer can't tell an idle session (user
# asleep) from a dead one (reboot / crash / kill -9 — no SessionEnd fires), so
# ghosts linger as 'active' for days AND their file claims keep blocking live
# sessions via the PreToolUse hook. tmux pane existence + a boot-epoch guard is
# ground truth and costs one ~5ms subprocess call.
# ---------------------------------------------------------------------------

_HOST = None
_BOOT_ID = None


def _host():
    global _HOST
    if _HOST is None:
        _HOST = socket.gethostname() or "unknown"
    return _HOST


def _boot_id():
    """A stable id for the current OS boot. Sessions whose stored boot_id
    differs are from a previous boot and are unambiguously dead. Best-effort:
    returns None if it can't be determined (then the boot guard is skipped)."""
    global _BOOT_ID
    if _BOOT_ID is not None:
        return _BOOT_ID or None  # cached "" sentinel means "unknown"
    val = ""
    try:
        if sys.platform == "darwin":
            out = subprocess.run(
                ["sysctl", "-n", "kern.boottime"],
                capture_output=True, text=True, timeout=2,
            ).stdout
            # "{ sec = 1781924595, usec = 54718 } Sat Jun 20 ..."
            import re
            m = re.search(r"sec\s*=\s*(\d+)", out)
            if m:
                val = m.group(1)
        else:  # linux: btime in /proc/stat
            with open("/proc/stat") as f:
                for line in f:
                    if line.startswith("btime "):
                        val = line.split()[1]
                        break
    except Exception:
        val = ""
    _BOOT_ID = val
    return val or None


def _live_tmux_panes():
    """Set of live tmux pane ids (e.g. {'%2','%28'}) across ALL sessions on
    this host. Returns None if tmux is unavailable / not running — callers must
    treat None as 'can't tell' and fall back to the timer rather than reaping
    everything."""
    pane = os.environ.get("TMUX_PANE")
    if not pane and not os.environ.get("TMUX"):
        return None
    try:
        result = subprocess.run(
            ["tmux", "list-panes", "-a", "-F", "#{pane_id}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0:
            return None
        panes = {p.strip() for p in result.stdout.splitlines() if p.strip()}
        return panes or None
    except Exception:
        return None


def _live_tmux_sessions():
    """Set of live tmux session NAMES on this host. Used as the reap fallback
    for rows with no recorded pane (e.g. legacy rows migrated in before the
    liveness columns existed) — claustrum's label IS the tmux session name.
    Returns None when tmux is unavailable (caller falls back to the timer)."""
    if not os.environ.get("TMUX"):
        return None
    try:
        result = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0:
            return None
        names = {n.strip() for n in result.stdout.splitlines() if n.strip()}
        return names or None
    except Exception:
        return None


def _pane_session_names():
    """Map of live tmux pane id -> its owning session NAME, across all sessions
    on this host. Claustrum's label IS the tmux session name, but a session
    renames itself (convention: `tmux rename-session <slug>`) AFTER it checks in,
    and the stored label is otherwise only re-derived on the next prompt. The
    heartbeat uses this to propagate a rename without waiting for a prompt.
    Returns None if tmux is unavailable."""
    if not os.environ.get("TMUX"):
        return None
    try:
        result = subprocess.run(
            ["tmux", "list-panes", "-a", "-F", "#{pane_id}\t#{session_name}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0:
            return None
        out = {}
        for line in result.stdout.splitlines():
            pane, _, name = line.partition("\t")
            pane, name = pane.strip(), name.strip()
            if pane and name:
                out[pane] = name
        return out or None
    except Exception:
        return None


# Interactive coding-agent CLIs whose tmux panes Claustrum tracks. Matched by
# path component / word so 'agy' can't hit 'legacy' etc. Extend as agents land.
_AGENT_NAMES = {"claude", "agy", "antigravity", "gemini", "gemma", "codex"}


def _is_agent_cmd(command):
    """True if a process command line is one of the tracked agent CLIs. Matches
    on a path component or whitespace-delimited token (so '.../bin/agy' and
    'node .../claude/cli.js' match, but 'legacy' does not)."""
    import re
    return any(t in _AGENT_NAMES for t in re.split(r"[\s/\\]+", command.lower()) if t)


def _live_agent_panes():
    """{pane_id: agent_pid} for tmux panes whose process subtree is running a
    tracked coding agent (claude / agy / …). Lets the heartbeat ADOPT a live
    agent session that has no claustrum row yet (its row was lost and it hasn't
    prompted since) so it shows without interaction — keyed on the agent pid so
    it reaps cleanly when the agent exits. One `tmux` + one `ps` snapshot, so it
    stays cheap on the per-tick path. None if tmux is down."""
    if not os.environ.get("TMUX"):
        return None
    try:
        r = subprocess.run(
            ["tmux", "list-panes", "-a", "-F", "#{pane_id}\t#{pane_pid}"],
            capture_output=True, text=True, timeout=2,
        )
        if r.returncode != 0:
            return None
        pane_pid = {}
        for line in r.stdout.splitlines():
            p, _, pid = line.partition("\t")
            if p.strip() and pid.strip():
                pane_pid[p.strip()] = pid.strip()
        ps = subprocess.run(
            ["ps", "-axo", "pid=,ppid=,command="],
            capture_output=True, text=True, timeout=3,
        )
        children, cmd = {}, {}
        for line in ps.stdout.splitlines():
            parts = line.split(None, 2)
            if len(parts) < 3:
                continue
            pid, ppid, c = parts
            children.setdefault(ppid, []).append(pid)
            cmd[pid] = c
        def agent_pid(root):
            # DFS the pane's subtree; return the first agent process pid found.
            seen, stack = set(), [root]
            while stack:
                pid = stack.pop()
                if pid in seen:
                    continue
                seen.add(pid)
                if _is_agent_cmd(cmd.get(pid, "")):
                    return pid
                stack.extend(children.get(pid, []))
            return None
        out = {}
        for pane, ppid in pane_pid.items():
            ap = agent_pid(ppid)
            if ap:
                out[pane] = ap
        return out or None
    except Exception:
        return None


def _pid_alive(pid, boot_id, cur_boot):
    """True if a recorded Claude pid is still running. Boot-guarded: a pid from a
    previous boot counts as dead (PID reuse across reboots). A missing or
    malformed pid is unverifiable, so returns True — we never reap on a guess.
    PermissionError means the pid exists under another user, i.e. alive."""
    if not pid:
        return True
    if cur_boot and boot_id and boot_id != cur_boot:
        return False
    try:
        os.kill(int(pid), 0)
        return True
    except ProcessLookupError:
        return False
    except (ValueError, TypeError):
        return True
    except PermissionError:
        return True


def _reap_dead(db, now):
    """Mark genuinely-dead local sessions 'dead' and release their stale file
    claims, using tmux/boot ground truth instead of the heartbeat timer.
    Cross-host sessions and any we can't verify are left to _clean_stale's
    timer. A false reap is self-healing — the session re-registers 'active' on
    its next heartbeat. Returns the list of reaped uids (callers that only need
    a count can take len())."""
    boot = _boot_id()
    host = _host()
    live_panes = _live_tmux_panes()
    live_sessions = _live_tmux_sessions()

    rows = db.execute(
        "SELECT uid, label, host, tmux_pane, pid, boot_id FROM sessions "
        "WHERE status IN ('active', 'stale')"
    ).fetchall()

    dead = []
    for s in rows:
        # Only adjudicate local sessions. A NULL host is a legacy/unknown row;
        # since the DB is single-machine, treat it as a local candidate so the
        # fallbacks below can still reap pre-upgrade ghosts.
        if s["host"] and s["host"] != host:
            continue

        # 1) Previous boot → definitively dead (handles reboot + PID reuse).
        if boot and s["boot_id"] and s["boot_id"] != boot:
            dead.append(s["uid"])
            continue

        # 2) Recorded a tmux pane.
        if s["tmux_pane"] and live_panes is not None:
            if s["tmux_pane"] not in live_panes:
                dead.append(s["uid"])           # pane gone → dead
                continue
            # Pane alive — but a tmux pane outlives its Claude process: quit
            # Claude and the shell/pane lingers. If we recorded the Claude pid
            # and it's gone, the session is dead despite the surviving pane. This
            # also dedups a reused pane — a stale registration's old pid is dead
            # while the current session's pid is alive on the same pane.
            if not _pid_alive(s["pid"], s["boot_id"], boot):
                dead.append(s["uid"])
            continue

        # 3) No pane recorded but tmux is up → match label against live tmux
        #    session names (covers legacy rows). Conservative: duplicate labels
        #    keep all matches alive, and a wrong reap self-heals.
        if not s["tmux_pane"] and live_sessions is not None and s["label"]:
            if _clean_label(s["label"]) not in live_sessions:
                dead.append(s["uid"])
            continue

        # 4) Non-tmux, but a pid is recorded → os.kill(pid,0) probe, boot-guarded
        #    so a reused PID can't resurrect a ghost.
        if not s["tmux_pane"] and s["pid"] and (not boot or s["boot_id"] == boot):
            try:
                os.kill(int(s["pid"]), 0)
            except (ProcessLookupError, ValueError):
                dead.append(s["uid"])
            except PermissionError:
                pass  # alive, owned by another user — treat as live
            continue

        # 5) Can't verify (no pane, no pid, tmux down) → leave to the timer.

    for uid in dead:
        db.execute("UPDATE sessions SET status = 'dead' WHERE uid = ?", (uid,))
        db.execute("DELETE FROM claims WHERE uid = ?", (uid,))

    return dead


def _clean_stale(db, now):
    """Mark stale sessions and release their claims. Returns count."""
    threshold = now - STALE_SECONDS
    stale = db.execute(
        "SELECT uid FROM sessions WHERE last_seen < ? AND status = 'active'",
        (threshold,)
    ).fetchall()

    for s in stale:
        db.execute(
            "UPDATE sessions SET status = 'stale' WHERE uid = ?",
            (s["uid"],)
        )
        db.execute("DELETE FROM claims WHERE uid = ?", (s["uid"],))

    # Purge old done/stale sessions and read messages. 'dead' sessions are
    # verified-gone (reaped by _reap_dead), so drop them right away rather than
    # waiting out CLEANUP_SECONDS — their uid never returns.
    old = now - CLEANUP_SECONDS
    db.execute("DELETE FROM sessions WHERE status = 'dead'")
    db.execute(
        "DELETE FROM sessions WHERE last_seen < ? AND status IN ('stale','done')",
        (old,),
    )
    db.execute(
        "DELETE FROM messages WHERE read_at IS NOT NULL AND read_at < ?",
        (old,),
    )

    return len(stale)


def _get_session_label():
    """Get a human-readable label for this terminal session.

    Fallback chain (first non-empty wins):
      1. CLAUSTRUM_LABEL env var (explicit override)
      2. tmux pane title (if inside tmux)
      3. iTerm2 tab name (macOS)
      4. Terminal.app window name (macOS)
      5. basename of working directory
    """
    # 1. Explicit override
    label = os.environ.get("CLAUSTRUM_LABEL", "").strip()
    if label:
        return label

    # 2. tmux session name (the slug set via tmux rename-session)
    try:
        pane = os.environ.get("TMUX_PANE")
        if pane:
            result = subprocess.run(
                ["tmux", "display-message", "-t", pane, "-p", "#{session_name}"],
                capture_output=True, text=True, timeout=2,
            )
            name = result.stdout.strip()
            if name:
                return name
    except Exception:
        pass

    # 3. iTerm2 tab name (only if iTerm2 is already running)
    # 4. Terminal.app window name (only if Terminal is already running)
    # `tell application "X"` launches X if not running, so guard with
    # System Events process check (does not launch the app).
    for app, query in (
        ("iTerm2", 'tell application "iTerm2" to get name of current tab of current window'),
        ("Terminal", 'tell application "Terminal" to get name of front window'),
    ):
        try:
            check = subprocess.run(
                ["osascript", "-e",
                 f'tell application "System Events" to (name of processes) contains "{app}"'],
                capture_output=True, text=True, timeout=2,
            )
            if check.stdout.strip().lower() != "true":
                continue
            result = subprocess.run(
                ["osascript", "-e", query],
                capture_output=True, text=True, timeout=2,
            )
            name = result.stdout.strip()
            if name and result.returncode == 0:
                return name
        except Exception:
            pass

    # 5. Directory basename as last resort
    return os.path.basename(os.getcwd())


def _clean_label(label):
    """Strip leading status indicators (braille, emoji, symbols) from labels.

    Pane titles may already contain status indicators from other tools
    (e.g. statusline). Strip them so Claustrum can prepend its own.
    """
    import re
    # Strip leading braille patterns (U+2800-U+28FF), common symbols, and whitespace
    return re.sub(r'^[\u2800-\u28FF✳◇◆●○■□▪▫★☆⚡🤖\s]+', '', label).strip()


def _ensure_session(db, uid, cwd=None):
    """Register or refresh a session, recording liveness fields (host, tmux
    pane, pid, boot id) so _reap_dead can verify it against the live OS/tmux
    state rather than guessing from a timer."""
    now = time.time()
    label = _get_session_label()
    host = _host()
    pane = os.environ.get("TMUX_PANE") or None
    # The hook runs as a child of the Claude process; its parent pid is the best
    # available process handle for liveness when there's no tmux pane.
    try:
        pid = os.getppid()
    except Exception:
        pid = None
    boot = _boot_id()
    # Privacy is read from THIS process's env, which is the session's (the hook
    # runs as a child of Claude). Set directly (not COALESCE) so toggling
    # CLAUSTRUM_PUBLIC mid-session updates the row. The heartbeat never calls
    # this, so it can't clobber the flag with its own (private-less) env.
    private = 1 if _privacy_mode() else 0
    db.execute(
        """
        INSERT INTO sessions
            (uid, label, status, cwd, last_seen, started_at,
             host, tmux_pane, pid, boot_id, private)
        VALUES (?, ?, 'active', ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(uid) DO UPDATE SET
            label = COALESCE(?, label),
            status = 'active',
            cwd = COALESCE(?, cwd),
            last_seen = ?,
            host = COALESCE(?, host),
            tmux_pane = COALESCE(?, tmux_pane),
            pid = COALESCE(?, pid),
            boot_id = COALESCE(?, boot_id),
            private = ?
        """,
        (uid, label, cwd, now, now, host, pane, pid, boot, private,
         label, cwd, now, host, pane, pid, boot, private),
    )


def _set_local_topic(db, uid, topic, confidence=None, domain=None):
    """Mirror a session's topic (+ domain) into the local DB so it's joinable
    offline by uid (the downstream nugget-miner joins transcripts → topics on the
    session uuid). Only writes when there's an actual topic; never clobbers an
    existing topic with NULL. Domain is written when provided (never nulled).
    Caller commits."""
    if not topic:
        return
    db.execute(
        "UPDATE sessions SET topic = ?, topic_confidence = ? WHERE uid = ?",
        (topic, confidence, uid),
    )
    if domain:
        db.execute(
            "UPDATE sessions SET domain = ? WHERE uid = ?", (domain, uid)
        )


# Tiny stopword set + tokenizer for the cheap, LLM-free auto-classifier. Kept
# deliberately small — this is keyword overlap, not NLP.
_STOPWORDS = frozenset(
    "the a an and or of to in on for with by at from is are be this that it as "
    "into via add adds added fix fixes fixed update updates updated make makes "
    "work working session claude code task new use using run running get".split()
)


def _tokenize(text):
    """Lowercase alphanumeric tokens, kebab/snake split, stopwords + 2-char
    noise dropped. Returns a set (overlap scoring, order-independent)."""
    if not text:
        return set()
    import re
    toks = re.split(r"[^a-z0-9]+", str(text).lower())
    return {t for t in toks if len(t) > 2 and t not in _STOPWORDS}


def _canonical_topic(taxonomy, name):
    """Resolve a VARIANT topic name onto its canonical parent using the taxonomy's
    `parent` field (e.g. 'gateway' -> 'mcp-gateway', 'wp' -> 'wordpress'). So the
    local mirror, the board and cross-machine collision detection all converge on
    one name instead of splitting across a variant and its canonical. An
    emergent/unknown name (not in the taxonomy) resolves to itself, keeping the
    taxonomy free-text. The server also resolves on write (classify_self) — this is
    the client-side mirror of that so an offline / heuristic / backstop pick is
    canonical too. Single-level (merged variants point straight at the canonical)."""
    if not name or not taxonomy:
        return name
    for t in taxonomy:
        if (t.get("name") or "").strip() == name:
            return (t.get("parent") or "").strip() or name
    return name


def _auto_classify_topic(taxonomy, signal, floor=False):
    """Cheap, local, LLM-free best-guess topic for an untagged session.

    Scores keyword overlap between the session's signal (task / repo / cwd /
    prompt — all of which stay on this machine) and each taxonomy topic's
    name+description. A name-token hit weighs 3x a description-token hit.

    Default (floor=False, the prompt path): picks the leader only if it clears a
    floor AND beats the runner-up, so weak/tied matches return (None, None) and
    fall through to the deliberate sub-agent classify (better quality).

    floor=True (the tick path): commits coverage ONLY when the signal grounds it —
    a UNIQUE leader (a real token the session actually contains) is committed at
    low confidence. A TIE or a no-overlap session returns (None, None): we never
    bucket into a generic catch-all 'app' topic, because a wrong coarse tag
    pollutes the board and fires false topic-collision alerts. Those untagged
    sessions are picked up by the full-context backstop / in-session directive,
    which classify from the real conversation (and can mint a specific topic). The
    named-turn sub-agent supersedes any floor pick (higher confidence). See the
    confidence-gated re-prompt in hook_prompt.

    Returns (topic_name, confidence) or (None, None). Confidence is capped below a
    human/LLM pick (80) so a later classify-self always supersedes the heuristic.
    """
    if not taxonomy:
        return None, None
    sig = _tokenize(signal)
    scored = []
    for t in taxonomy:
        name = (t.get("name") or "").strip()
        if not name:
            continue
        name_toks = _tokenize(name)
        desc_toks = _tokenize(t.get("description") or "")
        score = 3 * len(sig & name_toks) + len(sig & desc_toks)
        if score > 0:
            scored.append((score, name))
    if scored:
        scored.sort(reverse=True)
        best_score, best_name = scored[0]
        # Collapse a variant pick onto its canonical (e.g. 'gateway'->'mcp-gateway')
        # so the heuristic never emits a name that splits the board.
        best_name = _canonical_topic(taxonomy, best_name)
        runner = scored[1][0] if len(scored) > 1 else 0
        # Confident ONLY when there's a real signal (>=2) AND a clear lead. A
        # genuine signal here means a name-token hit (worth 3) or two distinct
        # description words — not a single common word.
        if best_score >= 2 and best_score > runner:
            return best_name, min(60, 30 + 5 * best_score)
        # Not confident, but on the tick floor a UNIQUE leader (best beats the
        # runner-up) is still grounded in a real token the session contains — so
        # commit it at low confidence rather than leaving it untagged. A TIE is
        # NOT committed: the reverse-name tiebreak would pick an arbitrary topic
        # (the 'server-down -> youtube-mcp' bug), so it falls through to None.
        if floor and best_score > runner:
            return best_name, min(25, 15 + 5 * best_score)
    # No confident or grounded floor pick (no overlap, or a tie). NEVER default to
    # a generic 'app' catch-all — a wrong coarse tag pollutes the board and fires
    # false topic-collision alerts. Leave it untagged; the full-context backstop +
    # in-session directive classify it from the real conversation.
    return None, None


def _read_transcript_text(path, kind="claude", max_chars=6000):
    """Extract recent user+assistant dialogue from a session transcript so the
    backstop classifies from the REAL conversation, not the 200-char task. Handles
    three agent formats via `kind`:
      - claude: JSONL, {"type":"user"|"assistant","message":{role,content}}
      - codex:  JSONL, {"type":"response_item","payload":{role,content:[{type,text}]}}
      - antigravity: a SQLite .db (steps.step_payload protobuf) -> string-scrape.
    Best-effort: missing / locked / garbled / unknown layout -> '' (never raises).
    Stays local; only the chosen topic NAME ever leaves the machine."""
    if not path:
        return ""
    if kind == "antigravity":
        return _scrape_sqlite_text(path, max_chars)
    try:
        parts = []
        with open(path, "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    o = json.loads(line)
                except Exception:
                    continue
                if kind == "codex":
                    if o.get("type") != "response_item":
                        continue
                    p = o.get("payload") or {}
                    role, content = p.get("role"), p.get("content")
                else:  # claude
                    if o.get("type") not in ("user", "assistant"):
                        continue
                    msg = o.get("message") or {}
                    role = msg.get("role") or o.get("type")
                    content = msg.get("content")
                if role not in ("user", "assistant"):
                    continue
                text = ""
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    text = " ".join(
                        c.get("text") or ""
                        for c in content
                        if isinstance(c, dict)
                        and c.get("type") in ("text", "input_text", "output_text")
                    )
                text = text.strip()
                if text:
                    parts.append(f"{role}: {text}")
        if not parts:
            return ""
        return "\n".join(parts)[-max_chars:]
    except Exception:
        return ""


def _scrape_sqlite_text(path, max_chars=6000):
    """Antigravity (agy) transcript reader. The conversation is a SQLite .db whose
    `steps.step_payload` holds protobuf (not JSON) — we don't have the proto schema,
    so scrape printable runs from the blobs, which reliably surfaces the user prompts
    + commands (enough for the classifier). Open READ-ONLY/immutable (agy keeps the
    db open). The user's framing is EARLY and recent work is LATE, so keep a head+tail
    budget rather than a pure tail. Best-effort -> '' on any error."""
    import re
    try:
        import sqlite3
        con = sqlite3.connect(f"file:{path}?mode=ro&immutable=1", uri=True)
        try:
            rows = con.execute("SELECT step_payload FROM steps").fetchall()
        finally:
            con.close()
    except Exception:
        return ""
    seen, chunks = set(), []
    for (pl,) in rows:
        b = pl if isinstance(pl, (bytes, bytearray)) else str(pl or "").encode("utf-8", "replace")
        for m in re.findall(rb"[\x20-\x7e]{5,}", bytes(b)):
            s = m.decode("ascii", "replace")
            if s not in seen:
                seen.add(s)
                chunks.append(s)
    text = " ".join(chunks)
    text = re.sub(r"\b[0-9a-f]{8}-[0-9a-f-]{12,}\b", " ", text)  # drop UUIDs
    text = re.sub(r"\b[0-9a-f]{16,}\b", " ", text)               # drop long hex
    text = re.sub(r"\s+", " ", text).strip()
    if len(text) <= max_chars:
        return text
    half = max_chars // 2
    return text[:half] + " ... " + text[-half:]


def _classify_cmd_topic(taxonomy, signal, confidence=CLASSIFY_BACKSTOP_CONF):
    """Headless backstop classifier. If CLAUSTRUM_CLASSIFY_CMD is set, run that
    command to pick a topic from the taxonomy for `signal` (ideally the session
    transcript). LLM-agnostic — the command is whatever CLI the user points it at
    (never hardcoded to claude).

    Contract:
      stdin  (JSON): {"signal": "<transcript or task+cwd+label>", "topics": [{"name","domain"}, ...]}
      stdout       : JSON {"topic": "...", "domain": "..."}  OR  first line = topic

    The returned topic MUST match a taxonomy name (case-insensitive) — an
    off-taxonomy pick returns (None, None) so the caller falls back to the keyword
    heuristic (the backstop never mints; minting is the in-session directive's
    job). The raw signal goes over stdin (not argv) so it never lands on the
    process table. The subprocess runs with CLAUSTRUM_PRIVATE=1 so a headless
    `claude -p` can't spawn a phantom claustrum session (recursion guard).

    Best-effort: any error / timeout / non-zero exit / unparseable output returns
    (None, None) silently. `confidence` is returned with the pick — below 80 so a
    deliberate human/sub-agent classify-self always supersedes the backstop.
    Returns (topic_name, confidence) or (None, None)."""
    cmd = os.environ.get("CLAUSTRUM_CLASSIFY_CMD")
    if not cmd or not taxonomy or not (signal or "").strip():
        return None, None
    try:
        valid = {}
        for t in taxonomy:
            name = (t.get("name") or "").strip()
            if name:
                valid[name.lower()] = name
        payload = json.dumps({
            "signal": signal,
            "topics": [
                {"name": n, "domain": (t.get("domain") or None)}
                for t in taxonomy
                for n in [(t.get("name") or "").strip()]
                if n
            ],
        })
        proc = subprocess.run(
            shlex.split(cmd), input=payload, text=True,
            capture_output=True, timeout=CLASSIFY_CMD_TIMEOUT,
            env={**os.environ, "CLAUSTRUM_PRIVATE": "1"},
        )
        if proc.returncode != 0 or not proc.stdout.strip():
            return None, None
        out = proc.stdout.strip()
        picked = None
        try:
            picked = (json.loads(out).get("topic") or "").strip()
        except Exception:
            picked = out.splitlines()[0].strip()
        match = valid.get(picked.lower()) if picked else None
        if not match:
            return None, None  # off-taxonomy — defer to the keyword heuristic
        # Collapse a variant pick onto its canonical so the backstop never lands a
        # session on a name that splits the board. Domain is derived server-side
        # from the topic, so we return topic only.
        return _canonical_topic(taxonomy, match), confidence
    except Exception:
        return None, None


def _floor_classify(taxonomy, signal, floor=False):
    """Per-turn / per-tick coverage floor: the zero-cost keyword heuristic. The
    pluggable CLAUSTRUM_CLASSIFY_CMD is NOT called here — it's the once-per-session
    heartbeat backstop now (_run_backstop), so an LLM never fires every turn. Same
    (topic, confidence) contract as _auto_classify_topic."""
    return _auto_classify_topic(taxonomy, signal, floor=floor)


def _find_transcript(uid, cwd=None):
    """Locate a session's transcript across agents. Returns (path, kind) or
    (None, None):
      - claude: ~/.claude/projects/*/<uid>.jsonl (file named by session id = our uid).
      - antigravity: ~/.gemini/antigravity-cli/conversations/<uid>.db (uid is the agy
        conversationId, via shared-hooks/agy-claustrum-guard.sh's checkin).
      - codex: no uid link (codex sessions are pane-adopted; the rollout is named by
        codex's own UUID), so correlate by cwd (see _find_codex_rollout_by_cwd)."""
    import glob
    if uid:
        m = glob.glob(os.path.expanduser(f"~/.claude/projects/*/{uid}.jsonl"))
        if m:
            return m[0], "claude"
        agy = os.path.expanduser(f"~/.gemini/antigravity-cli/conversations/{uid}.db")
        if os.path.exists(agy):
            return agy, "antigravity"
    if cwd:
        codex = _find_codex_rollout_by_cwd(cwd)
        if codex:
            return codex, "codex"
    return None, None


def _find_codex_rollout_by_cwd(cwd):
    """Best-effort codex rollout locator: rollouts are named by codex's own UUID, not
    our uid, so match on cwd. Scan the newest ~/.codex/sessions/**/rollout-*.jsonl,
    read each first line (session_meta) for its cwd, return the NEWEST whose cwd ==
    this session's cwd. Bounded to the newest 50 files so a long history can't slow
    the tick. None on no match / any error (caller falls back to the heuristic)."""
    import glob
    try:
        target = os.path.abspath(cwd)
        files = glob.glob(os.path.expanduser("~/.codex/sessions/**/rollout-*.jsonl"),
                          recursive=True)
        files.sort(key=lambda p: os.path.getmtime(p), reverse=True)
        for p in files[:50]:
            try:
                with open(p, "r") as f:
                    o = json.loads(f.readline())
                meta = o.get("payload") if isinstance(o.get("payload"), dict) else o
                rc = (meta or {}).get("cwd")
                if rc and os.path.abspath(rc) == target:
                    return p
            except Exception:
                continue
    except Exception:
        pass
    return None


def _run_backstop(uid):
    """Once-per-session headless backstop. When the in-session sub-agent directive
    didn't land a confident classification, classify this LOCAL session from its
    FULL transcript via CLAUSTRUM_CLASSIFY_CMD — so a session whose agent ignored
    the directive (or guessed off the slug) still gets a context-grounded
    domain+topic, not a coarse floor 'app'.

    Fires only when: a backstop command is configured; still below the confidence
    floor; has attempts left; NOT in the Claude in-session-directive window
    (0 < turn_count <= CLASSIFY_MIN_TURN is skipped; turn_count==0 = non-Claude/
    adopted, allowed); and a transcript is readable (claude/codex/antigravity via
    _find_transcript). backstop_done counts
    ATTEMPTS — a transient model blip increments it and retries on a later tick
    (up to CLASSIFY_BACKSTOP_ATTEMPTS), while a SUCCESS jumps to the cap so it
    never re-runs. Returns True if it consumed a run this tick (caller caps one per
    tick). Best-effort; never raises."""
    if not os.environ.get("CLAUSTRUM_CLASSIFY_CMD"):
        return False
    try:
        db = get_db()
        try:
            row = db.execute(
                "SELECT topic_confidence, turn_count, backstop_done, transcript_path, cwd, label "
                "FROM sessions WHERE uid = ?", (uid,)
            ).fetchone()
        finally:
            db.close()
        if not row:
            return False
        conf = row["topic_confidence"] or 0
        turns = row["turn_count"] or 0
        attempts = row["backstop_done"] or 0
        if attempts >= CLASSIFY_BACKSTOP_ATTEMPTS or conf >= CLASSIFY_CONF_FLOOR:
            return False
        # Don't race the in-session sub-agent directive: skip the Claude pre/at-directive
        # window (0 < turn_count <= CLASSIFY_MIN_TURN). turn_count==0 means a non-Claude
        # / adopted session (no directive to race) — those are exactly what the backstop
        # is for, so allow them.
        if 0 < turns <= CLASSIFY_MIN_TURN:
            return False
        # Locate the transcript across agents (claude/codex/antigravity). The Claude
        # hook captures transcript_path directly; otherwise correlate by uid/cwd.
        tpath, tkind = row["transcript_path"], "claude"
        if not tpath:
            tpath, tkind = _find_transcript(uid, row["cwd"])
        text = _read_transcript_text(tpath, tkind, max_chars=CLASSIFY_BACKSTOP_CHARS) if tpath else ""
        if not text:
            return False  # no transcript yet — retry a later tick (attempt not spent)
        taxonomy = _cloud_topics()
        if not taxonomy:
            return False  # cloud unavailable — retry later
        # The curated session name (tmux label) is a strong, clean prior — pass it
        # ahead of the transcript so the classifier weights it (a "Review-Slack-
        # thread" session should never land on a coarse 'gateway'/'gcp' bucket).
        label = (row["label"] or "").strip()
        signal = f"SESSION NAME: {label}\n\n{text}" if label else text
        topic, tconf = _classify_cmd_topic(taxonomy, signal, confidence=CLASSIFY_BACKSTOP_CONF)
        # Count the attempt. On success jump to the cap so it never re-runs; on a
        # blank/garbled result just increment, so a transient blip retries later
        # rather than permanently disabling the backstop for this session.
        new_attempts = CLASSIFY_BACKSTOP_ATTEMPTS if topic else attempts + 1
        db = get_db()
        try:
            db.execute("UPDATE sessions SET backstop_done = ? WHERE uid = ?", (new_attempts, uid))
            if topic:
                _set_local_topic(db, uid, topic, tconf)
            db.commit()
        finally:
            db.close()
        if topic:
            _cloud_classify_self(uid, topic, confidence=tconf,
                                 timeout=CLOUD_TIMEOUT_INTERACTIVE)
        return True
    except Exception:
        return False


def _format_ago(seconds):
    s = int(seconds)
    if s < 60:
        return f"{s}s ago"
    if s < 3600:
        return f"{s // 60}m ago"
    return f"{s // 3600}h ago"


def _short_email(email):
    """`joe.waller@finder.com` -> `joe.waller` for compact peer lines."""
    if not email:
        return "someone"
    return email.split("@", 1)[0]


def _format_date(ts):
    """ISO timestamp string -> `YYYY-MM-DD` for compact display. Falls back to
    the raw value on anything unexpected."""
    if not ts:
        return "?"
    return str(ts)[:10]


def _render_cloud_tiers(tiers):
    """Render the /v1/list tiered-overlap result for the heartbeat tray. t1/t2
    are collisions (someone is on YOUR files / PR) and get surfaced loudly;
    t3/t4 are softer "also in this topic/repo" counts. Returns a list of lines
    (empty if nothing worth showing)."""
    if not isinstance(tiers, dict):
        return []

    t1 = tiers.get("t1_file_overlap") or []
    t2 = tiers.get("t2_path_or_pr") or []
    t3 = tiers.get("t3_topic") or {}
    t4 = tiers.get("t4_repo") or {}

    lines = []

    if t1:
        lines.append("  ⚠️  CROSS-MACHINE FILE COLLISION — someone is already editing your files:")
        for p in t1:
            who = _short_email(p.get("user_email"))
            files = ", ".join(p.get("overlap_files") or []) or "?"
            on = p.get("working_on") or p.get("topic") or "-"
            lines.append(f"      • {who} ({p.get('machine','?')}): {files}  — {on}")

    if t2:
        lines.append("  ⚠️  Same PR / directory as you:")
        for p in t2:
            who = _short_email(p.get("user_email"))
            reason = p.get("reason") or ""
            on = p.get("working_on") or p.get("topic") or "-"
            lines.append(f"      • {who} ({p.get('machine','?')}) [{reason}] — {on}")

    if isinstance(t3, dict) and t3.get("count"):
        topic = t3.get("topic") or "?"
        peers = ", ".join(
            _short_email(p.get("user_email")) for p in (t3.get("peers") or [])
        )
        extra = f" ({peers})" if peers else ""
        lines.append(f"  · {t3['count']} other session(s) on topic '{topic}'{extra}")

    if isinstance(t4, dict) and t4.get("count"):
        repo = t4.get("repo") or "?"
        lines.append(f"  · {t4['count']} other session(s) in repo '{repo}'")

    if lines:
        lines.insert(0, "Cross-machine (claustrum cloud):")
    return lines


# Tiers surfaced loudly (high-signal: same files / same PR-or-dir). Topic / repo
# matches (t3/t4) are weaker — a quiet footnote, not a banner — so the "already
# solved" warning doesn't cry wolf on every repo-mate.
_LOUD_SOLVED_TIERS = ("t1_file_overlap", "t2_path_or_pr")


def _format_solved_entry(s):
    """One human line for a solved-archive match. `s` is a server `solved`
    entry: {person, repo, topic, pr_number, done_at, resolution, match_tier,
    overlap_files?}."""
    who = _short_email(s.get("person"))
    when = _format_date(s.get("done_at"))
    res = str(s.get("resolution") or "").strip() or "(no resolution recorded)"
    pr = s.get("pr_number")
    pr_s = f" (PR #{pr})" if pr else ""
    overlap = s.get("overlap_files") or []
    where = ", ".join(overlap) if overlap else (s.get("repo") or s.get("topic") or "?")
    return f"{who}, {when} — {res}{pr_s}  [{where}]"


def _render_solved(solved):
    """Render the 'has this been solved before?' block for the turn-1 tray.
    Loud tiers (file / PR overlap) get a warning banner; weak tiers (topic /
    repo) are a one-line footnote. Returns a list of lines (empty if none)."""
    if not solved:
        return []
    # Only surface entries with a real resolution — a bare done row (no
    # resolution recorded) is board state, not useful "solved" knowledge, so
    # showing it is just noise.
    solved = [s for s in solved if str(s.get("resolution") or "").strip()]
    if not solved:
        return []

    # Dedup: the same completed work can match on several tiers / rows (e.g. one
    # PR surfacing three times), which is pure noise in the tray. Collapse by
    # (person, pr, resolution) — the identity of the solved work, not the match.
    def _dedup(entries):
        seen = set()
        out = []
        for s in entries:
            key = (
                s.get("person"),
                s.get("pr_number"),
                str(s.get("resolution") or "").strip(),
            )
            if key in seen:
                continue
            seen.add(key)
            out.append(s)
        return out

    loud = _dedup([s for s in solved if s.get("match_tier") in _LOUD_SOLVED_TIERS])
    weak = _dedup([s for s in solved if s.get("match_tier") not in _LOUD_SOLVED_TIERS])

    lines = []
    if loud:
        lines.append("  \U0001f5c2️  MAY ALREADY BE SOLVED — matching work was completed before:")
        for s in loud:
            lines.append(f"      • {_format_solved_entry(s)}")
    if weak:
        lines.append("  \U0001f5c2️  Related solved work (weaker match — same topic/repo):")
        for s in weak[:3]:
            lines.append(f"      • {_format_solved_entry(s)}")
    return lines


def _mirror_or_autoclassify(db, uid, checkin_resp, signal):
    """Keep the local topic mirror in sync from the cloud checkin response.

    Two cases, both writing the LOCAL DB only (no network here — the caller
    fires the cloud push after the DB is closed so it never holds a lock open
    across a request):
      - cloud already has a topic  -> mirror it straight down locally.
      - cloud wants a topic + sent a taxonomy -> cheap local heuristic pick;
        on a confident match, write it locally and return it so the caller can
        best-effort push it to the cloud too.

    Returns (auto_topic, auto_conf) when THIS turn auto-picked a topic (caller
    then pushes it to the cloud + can surface a note), else (None, None)."""
    if not isinstance(checkin_resp, dict):
        return None, None
    existing = checkin_resp.get("topic")
    if existing:
        _set_local_topic(db, uid, existing, checkin_resp.get("topic_confidence"),
                         domain=checkin_resp.get("domain"))
        return None, None
    if not checkin_resp.get("topic_required"):
        return None, None
    topic, conf = _floor_classify(checkin_resp.get("taxonomy") or [], signal)
    if topic:
        _set_local_topic(db, uid, topic, conf)
        return topic, conf
    return None, None


def _build_classify_block(uid, transcript_path=None):
    """Directive (fired ONCE, at turn >= CLASSIFY_MIN_TURN) telling the working
    agent to classify this session via a SUB-AGENT.

    Why a sub-agent: classification needs searching — read the domains+topics
    taxonomy, maybe memory, reconcile near-duplicates. Doing that inline would
    spend that token cost in EVERY working session's main context. A sub-agent
    keeps it in a disposable context; the main session pays only this short
    directive.

    Why FULL context: a spawned sub-agent does NOT inherit this conversation, so
    with no context it classifies off the bare session name — the failure we saw
    ('Fix-findrshopping-...' -> 'app'). The fix is to hand it the WHOLE chat:
    point it at this session's transcript file (the complete conversation) so it
    classifies on what the work ACTUALLY is, not the opening slug. The transcript
    path is known to the hook; if it's missing (non-Claude agent), fall back to a
    2-3 sentence brief written from the work done.

    Fired once (no nagging); the heartbeat backstop covers a session whose agent
    ignores this. The same sub-agent also fixes the tmux session name — killing
    the stale-name problem (turn-1 names that never update) at the same source as
    the topic. Returns a list of lines."""
    lines = [
        "Claustrum: classify this session now (no confident domain+topic yet).",
        "  Spawn a sub-agent (keeps the taxonomy lookup out of this context). It does",
        "  NOT inherit this chat, so give it the FULL context — classify on the actual",
        "  work, NOT the session name:",
    ]
    if transcript_path:
        lines.append(f"    - tell it to read the whole transcript at {transcript_path}")
        lines.append("      (the complete conversation) and classify from what the work IS")
    else:
        lines.append("    - give it a 2-3 sentence brief of what this session is ACTUALLY")
        lines.append("      about — from the work you've done (ticket / files / memory here)")
    lines += [
        "  Tell the sub-agent to:",
        "    1. run  claustrum domains   and   claustrum topics",
        "    2. pick the best-fit domain + topic; if nothing fits, run",
        f"         claustrum propose-domain {uid} \"<name>\" \"<desc>\"   (only if no domain fits)",
        f"         claustrum propose-topic {uid} \"<name>\" \"<desc>\" --domain \"<domain>\"",
        f"    3. run  claustrum classify-self {uid} \"<topic>\" --domain \"<domain>\"",
        "       (claustrum maps near-duplicates onto existing names automatically)",
        "    4. if the tmux session name no longer fits, rename it to a short 2-4 word",
        "       slug:  tmux rename-session \"<slug>\"  (the board name should match the work)",
    ]
    return lines


def _build_drift_block(uid, topic, domain, recent_files):
    """Cadence re-surface for an ALREADY-classified session: show its current
    topic+domain (and recently-claimed files) and ask the agent to sanity-check
    the FIT — catching BOTH drift (the work moved on) AND an initial
    misclassification (confident-but-wrong, e.g. the 'app@80' case). LLM-agnostic
    — the agent judges against its own live context. Returns a list of lines."""
    lines = [
        f"Claustrum: this session is currently topic=\"{topic}\" / domain=\"{domain or '?'}\".",
    ]
    if recent_files:
        lines.append(f"  Recent files: {', '.join(recent_files)}")
    lines.append("  Is that still the best fit for what you're working on? If it has DRIFTED")
    lines.append("  or was misclassified, correct it (spawn a sub-agent if useful) with:")
    lines.append(f"    claustrum classify-self {uid} \"<topic>\" --domain \"<domain>\"")
    lines.append("  (If it's accurate, ignore this.)")
    return lines


