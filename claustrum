def cmd_send(args):
    """Send a message to another session or broadcast."""
    db = get_db()
    now = time.time()
    to_uid = None if args.to == "all" else args.to

    db.execute(
        """
        INSERT INTO messages (from_uid, to_uid, type, body, created_at)
        VALUES (?, ?, ?, ?, ?)
        """,
        (args.uid, to_uid, args.type, args.body, now),
    )
    db.commit()
    db.close()

    target = args.to if args.to != "all" else "all sessions"
    print(f"Message sent to {target}.")


def cmd_claim(args):
    """Claim a file for exclusive editing."""
    db = get_db()
    now = time.time()

    conflict = db.execute(
        """
        SELECT c.uid, s.task FROM claims c
        JOIN sessions s ON c.uid = s.uid
        WHERE c.filepath = ? AND c.uid != ? AND s.status = 'active'
        """,
        (args.file, args.uid),
    ).fetchone()

    if conflict:
        db.close()
        task_info = f" ({conflict['task']})" if conflict["task"] else ""
        print(
            f"CONFLICT: {args.file} claimed by "
            f"{conflict['uid'][:12]}{task_info}",
            file=sys.stderr,
        )
        sys.exit(1)

    db.execute(
        "INSERT OR REPLACE INTO claims (filepath, uid, claimed_at) VALUES (?,?,?)",
        (args.file, args.uid, now),
    )
    db.commit()
    db.close()
    print(f"Claimed {args.file}")

    # Cross-machine: register a soft claim in the cloud (repo-relative path) and
    # surface any peers already on it. Best-effort — local claim stands either
    # way. PreToolUse enforcement remains same-machine + local.
    repo, _ = _git_info(os.path.dirname(args.file) or None)
    rel = _rel_to_repo(args.file)
    cloud = _cloud_claim(args.uid, repo, rel)
    if cloud and cloud.get("conflicts"):
        print("Cross-machine: also claimed by", file=sys.stderr)
        for c in cloud["conflicts"]:
            who = c.get("user_email") or (c.get("uid") or "")[:12]
            wo = f" — {c['working_on']}" if c.get("working_on") else ""
            print(f"  {(c.get('uid') or '')[:12]} ({who}){wo}", file=sys.stderr)


def cmd_release(args):
    """Release a file claim."""
    db = get_db()
    db.execute(
        "DELETE FROM claims WHERE filepath = ? AND uid = ?",
        (args.file, args.uid),
    )
    db.commit()
    db.close()
    print(f"Released {args.file}")

    # Mirror the release to the cloud soft claim (best-effort).
    repo, _ = _git_info(os.path.dirname(args.file) or None)
    rel = _rel_to_repo(args.file)
    _cloud_release(args.uid, repo, rel)


def cmd_done(args):
    """Mark session as done, release claims, optionally broadcast summary, and
    publish to the cloud solved-archive so future sessions matching this work
    are told it was already solved (by whom, when, how)."""
    db = get_db()
    now = time.time()

    db.execute(
        "UPDATE sessions SET status = 'done', last_seen = ? WHERE uid = ?",
        (now, args.uid),
    )
    db.execute("DELETE FROM claims WHERE uid = ?", (args.uid,))

    if args.summary:
        db.execute(
            """
            INSERT INTO messages (from_uid, to_uid, type, body, created_at)
            VALUES (?, NULL, 'done', ?, ?)
            """,
            (args.uid, args.summary, now),
        )

    db.commit()
    db.close()

    # Cloud write-through: status=done + a value-scrubbed resolution feeds the
    # Phase-5 solved-archive (best-effort; honors the privacy gate internally,
    # silent on offline / private / server error). Fall back to the broadcast
    # summary as the resolution when --resolution isn't given.
    resolution = args.resolution or args.summary
    _cloud_update(args.uid, status="done", resolution=resolution)

    print(f"Session {args.uid[:12]} marked as done.")
    if resolution:
        print(f"  archived resolution: {resolution}")


def cmd_status(_args):
    """Show all active sessions, claims, and unread messages."""
    # Cross-machine peer merge: the live /v1/list tiered overlap is rendered in
    # the UserPromptSubmit heartbeat tray (hook_prompt), which has the session
    # UID. `claustrum status` is a same-machine snapshot and has no current UID
    # to filter against, so it stays local-only. To surface cloud peers here
    # too, plumb a session UID through (e.g. CLAUSTRUM_SESSION_UID) and call
    # _cloud_list_peers(uid) alongside the local query.
    db = get_db()
    now = time.time()
    _reap_dead(db, now)
    _clean_stale(db, now)
    db.commit()

    sessions = db.execute(
        """
        SELECT uid, label, task, working_on, status, cwd, last_seen, started_at
        FROM sessions
        WHERE status IN ('active', 'stale')
        ORDER BY last_seen DESC
        """,
    ).fetchall()

    if not sessions:
        print("No active sessions.")
        db.close()
        return

    # Dynamically size name column to fit the longest session name
    names = []
    for s in sessions:
        n = _clean_label(s["label"]) if s["label"] else s["uid"][:12]
        names.append(n)
    # Minimum 12, pad +2 for spacing
    name_w = max(max(len(n) for n in names), 12) + 2

    # Get terminal width and size the task column to fill remaining space
    try:
        term_w = os.get_terminal_size().columns
    except (OSError, ValueError):
        term_w = 120
    # Fixed columns: status(8) + last_seen(10) + spaces between = ~20
    fixed_w = name_w + 8 + 10 + 4  # name + status + ago + padding
    task_w = max(term_w - fixed_w - 2, 15)  # at least 15 chars for task

    print(
        f"{'Name':<{name_w}} {'Status':<8} {'Last Seen':<10} {'Task'}"
    )
    print("-" * min(term_w, name_w + 8 + 10 + task_w + 4))

    for s, name in zip(sessions, names):
        ago = _format_ago(now - s["last_seen"])
        task = (s["task"] or "-")[:task_w]
        print(
            f"{name:<{name_w}} {s['status']:<8} {ago:<10} {task}"
        )

    claims = db.execute(
        """
        SELECT c.filepath, c.uid FROM claims c
        JOIN sessions s ON c.uid = s.uid
        WHERE s.status = 'active'
        ORDER BY c.filepath
        """,
    ).fetchall()

    if claims:
        print(f"\nFile claims:")
        for c in claims:
            print(f"  {c['filepath']}  \u2190 {c['uid'][:12]}")

    unread = db.execute(
        "SELECT COUNT(*) as cnt FROM messages WHERE read_at IS NULL"
    ).fetchone()
    if unread["cnt"]:
        print(f"\n{unread['cnt']} unread message(s)")

    db.close()


def cmd_show(args):
    """Full detail for one session — the on-demand drill-in the lightweight
    heartbeat tray points at. Resolve `target` by exact uid, then exact label,
    then case-insensitive label substring. Prints task, working_on, claimed
    files, cwd, and live-state."""
    db = get_db()
    now = time.time()
    _reap_dead(db, now)
    db.commit()
    target = args.target

    row = db.execute(
        "SELECT * FROM sessions WHERE uid = ?", (target,)
    ).fetchone()
    if not row:
        rows = db.execute(
            "SELECT * FROM sessions WHERE label = ? COLLATE NOCASE", (target,)
        ).fetchall()
        if not rows:
            like = f"%{target}%"
            rows = db.execute(
                "SELECT * FROM sessions WHERE label LIKE ? COLLATE NOCASE "
                "ORDER BY last_seen DESC",
                (like,),
            ).fetchall()
        if len(rows) > 1:
            print(f"Ambiguous — {len(rows)} sessions match '{target}':")
            for r in rows:
                print(f"  {_clean_label(r['label'] or r['uid'][:12])}  ({r['uid'][:12]})")
            db.close()
            return
        row = rows[0] if rows else None

    if not row:
        print(f"No session matching '{target}'. Try `claustrum status`.")
        db.close()
        return

    live_panes = _live_tmux_panes()
    if row["host"] and row["host"] != _host():
        live = "remote host"
    elif row["tmux_pane"] and live_panes is not None:
        live = "live" if row["tmux_pane"] in live_panes else "DEAD (pane gone)"
    else:
        live = row["status"]

    name = _clean_label(row["label"]) if row["label"] else row["uid"][:12]
    print(f"{name}  ({row['uid']})")
    print(f"  status:     {row['status']}  [{live}]")
    print(f"  host:       {row['host'] or '?'}  pane {row['tmux_pane'] or '-'}  pid {row['pid'] or '-'}")
    print(f"  cwd:        {row['cwd'] or '?'}")
    print(f"  last seen:  {_format_ago(now - row['last_seen'])}")
    print(f"  task:       {row['task'] or '-'}")
    if row["working_on"]:
        print(f"  working on: {row['working_on']}")

    claims = db.execute(
        "SELECT filepath FROM claims WHERE uid = ? ORDER BY filepath",
        (row["uid"],),
    ).fetchall()
    if claims:
        print("  claimed files:")
        for c in claims:
            print(f"    • {c['filepath']}")
    db.close()


def cmd_archive(args):
    """Browse the solved-problem archive — completed work matching the filters,
    newest first, paginated. The archive is cloud-only (no local mirror), so
    this reads /v1/archive directly; prints how to fetch the next page."""
    resp = _cloud_archive(
        repo=args.repo, topic=args.topic, person=args.person,
        limit=args.limit, offset=args.offset,
    )
    if resp is None:
        print("Archive unavailable (cloud unreachable, or this session is private).")
        return

    items = resp.get("items") or []
    filt = []
    if args.repo:
        filt.append(f"repo={args.repo}")
    if args.topic:
        filt.append(f"topic={args.topic}")
    if args.person:
        filt.append(f"person={args.person}")
    filt_s = ("  (" + ", ".join(filt) + ")") if filt else ""

    if not items:
        print(f"No solved work in the archive{filt_s}.")
        return

    print(f"\U0001f5c2️  Solved-problem archive{filt_s}")
    print(f"   {len(items)} entr{'y' if len(items) == 1 else 'ies'} from offset {args.offset}")
    print()
    for it in items:
        who = _short_email(it.get("user_email"))
        when = _format_date(it.get("done_at"))
        res = str(it.get("resolution") or "").strip() or "(no resolution recorded)"
        pr = it.get("pr_number")
        pr_s = f" (PR #{pr})" if pr else ""
        where = it.get("repo") or it.get("topic") or "?"
        cold = "  ·cold" if it.get("archived") else ""
        print(f"  • {who}, {when} — {res}{pr_s}  [{where}]{cold}")

    if resp.get("has_more"):
        nxt = args.offset + args.limit
        more = f"claustrum archive --offset {nxt}"
        if args.limit != 20:
            more += f" --limit {args.limit}"
        if args.repo:
            more += f" --repo {args.repo}"
        if args.topic:
            more += f" --topic {args.topic}"
        if args.person:
            more += f" --person {args.person}"
        print()
        print(f"  … more — next page:  {more}")


def cmd_gc(_args):
    """Garbage-collect stale sessions, old messages, orphaned claims."""
    db = get_db()
    now = time.time()

    _reap_dead(db, now)
    _clean_stale(db, now)
    removed = db.execute(
        "DELETE FROM sessions WHERE status IN ('stale', 'done', 'dead')"
    ).rowcount
    old = now - 600
    msgs = db.execute(
        "DELETE FROM messages WHERE read_at IS NOT NULL AND read_at < ?",
        (old,),
    ).rowcount
    orphaned = db.execute(
        """
        DELETE FROM claims
        WHERE uid NOT IN (SELECT uid FROM sessions WHERE status = 'active')
        """,
    ).rowcount

    db.commit()
    db.close()
    print(
        f"Cleaned: {removed} sessions, {msgs} messages, "
        f"{orphaned} orphaned claims"
    )


def cmd_reset(args):
    """Nuclear option — clear everything."""
    db = get_db()
    db.executescript("DELETE FROM sessions; DELETE FROM messages; DELETE FROM claims;")
    db.close()
    print("Claustrum reset. All sessions, messages, and claims cleared.")

    if getattr(args, "cloud", False):
        result = _cloud_reset()
        if result is None:
            print(
                "Cloud reset failed (no CLAUSTRUM_CLOUD_URL, private mode, or "
                "offline). Local DB cleared regardless.",
                file=sys.stderr,
            )
        else:
            d = result.get("deleted") or {}
            print(
                "Cloud rows cleared: "
                f"{d.get('sessions', 0)} session(s), "
                f"{d.get('messages', 0)} message(s), "
                f"{d.get('claims', 0)} claim(s), "
                f"{d.get('topic_proposals', 0)} proposal(s)."
            )


def cmd_inbox(args):
    """Drain this session's cross-machine inbox (cloud) and print the messages.
    Also persists them to ~/.claustrum/inbox/<uid>.json."""
    msgs = _cloud_inbox_drain(args.uid)
    if msgs is None:
        print(
            "Cloud inbox unavailable (no CLAUSTRUM_CLOUD_URL, private mode, or "
            "offline).",
            file=sys.stderr,
        )
        return
    _persist_inbox(args.uid, msgs)
    if not msgs:
        print("Inbox empty.")
        return
    for m in msgs:
        sender = m.get("from_uid") or "system"
        print(f"[{m.get('type', 'info')}] {sender}: {m.get('body', '')}")


def cmd_resume_check(args):
    """Print the since-last-seen summary for this session (cloud)."""
    resume = _cloud_resume_check(args.uid)
    if resume is None:
