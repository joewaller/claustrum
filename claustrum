def main():
    parser = argparse.ArgumentParser(
        description="Claustrum \u2014 Unconscious coordination for Claude Code sessions",
    )
    sub = parser.add_subparsers(dest="command")

    # -- hook (called by Claude Code hooks, reads JSON from stdin) --
    hook_p = sub.add_parser("hook", help="Handle hook events (internal)")
    hook_sub = hook_p.add_subparsers(dest="event")
    hook_sub.add_parser("prompt")
    hook_sub.add_parser("pre-tool")
    hook_sub.add_parser("post-tool")
    hook_sub.add_parser("start")
    hook_sub.add_parser("stop")

    # -- checkin --
    p = sub.add_parser("checkin", help="Register or update a session")
    p.add_argument("--uid", required=True)
    p.add_argument("--task")
    p.add_argument("--files")
    p.add_argument("--cwd")
    p.add_argument(
        "--private",
        action="store_true",
        help="Skip cloud publish for this invocation (same effect as CLAUSTRUM_PRIVATE=1)",
    )

    # -- heartbeat --
    p = sub.add_parser(
        "heartbeat",
        help="Refresh liveness for live local sessions (cloud + local last_seen)",
    )
    p.add_argument(
        "--tmux-session",
        dest="tmux_session",
        help="Only refresh sessions in this tmux session (its name is the session label)",
    )

    # -- update --
    p = sub.add_parser("update", help="Update session info")
    p.add_argument("--uid", required=True)
    p.add_argument("--task")
    p.add_argument("--status")
    p.add_argument("--files", help="Value-scrubbed 'working_on' line (also cloud detail)")
    p.add_argument(
        "--private",
        action="store_true",
        help="Skip cloud publish for this invocation",
    )

    # -- classify-self (cloud: set this session's topic + domain) --
    p = sub.add_parser("classify-self", help="Tag this session with a topic (+ domain)")
    p.add_argument("uid")
    p.add_argument("topic")
    p.add_argument("--confidence", type=int, default=80)
    p.add_argument(
        "--domain",
        help="Domain to record on the session (default: derived from the topic)",
    )

    # -- topics (cloud: list the canonical taxonomy, for a classifying sub-agent) --
    sub.add_parser(
        "topics",
        help="List the canonical topic taxonomy (for a classifying sub-agent)",
    )

    # -- domains (cloud: list the canonical domain taxonomy, for a sub-agent) --
    sub.add_parser(
        "domains",
        help="List the canonical domain taxonomy (for a classifying sub-agent)",
    )

    # -- propose-topic (cloud: grow the emergent taxonomy) --
    p = sub.add_parser("propose-topic", help="Propose a new topic for the taxonomy")
    p.add_argument("uid")
    p.add_argument("name")
    p.add_argument("description")
    p.add_argument(
        "--domain",
        help="Domain the topic belongs to (default 'general'; must already exist)",
    )

    # -- propose-domain (cloud: grow the emergent domain taxonomy) --
    p = sub.add_parser("propose-domain", help="Propose a new domain for the taxonomy")
    p.add_argument("uid")
    p.add_argument("name")
    p.add_argument("description")

    # -- send --
    p = sub.add_parser("send", help="Send a message")
    p.add_argument("--uid", required=True, help="Your session UID")
    p.add_argument("--to", default="all", help="Target UID or 'all'")
    p.add_argument("--type", default="info")
    p.add_argument("--body", required=True)

    # -- claim --
    p = sub.add_parser("claim", help="Claim a file")
    p.add_argument("--uid", required=True)
    p.add_argument("--file", required=True)

    # -- release --
    p = sub.add_parser("release", help="Release a file claim")
    p.add_argument("--uid", required=True)
    p.add_argument("--file", required=True)

    # -- done --
    p = sub.add_parser("done", help="Mark session as done")
    p.add_argument("--uid", required=True)
    p.add_argument("--summary", help="Broadcast a done message to other sessions")
    p.add_argument(
        "--resolution",
        help="Value-scrubbed summary of how it was resolved (PR/commit/deploy). "
             "Feeds the cloud solved-archive. Falls back to --summary if omitted.",
    )

    # -- status / show / gc / reset / install / uninstall --
    sub.add_parser("status", help="Show all sessions")

    p = sub.add_parser(
        "show", help="Full detail for one session (by name or uid)"
    )
    p.add_argument("target", help="Session name (or substring) or uid")

    p = sub.add_parser("archive", help="Browse the solved-problem archive (completed work, any age)")
    p.add_argument("--repo", help="Filter by repo")
    p.add_argument("--topic", help="Filter by topic")
    p.add_argument("--person", help="Filter by author email")
    p.add_argument("--limit", type=int, default=20, help="Page size (1-200, default 20)")
    p.add_argument("--offset", type=int, default=0, help="Page offset (default 0)")

    sub.add_parser("gc", help="Clean up stale data")
    p = sub.add_parser("reset", help="Clear everything")
    p.add_argument(
        "--cloud",
        action="store_true",
        help="Also POST /v1/reset to delete this user's cloud rows",
    )
    p = sub.add_parser("inbox", help="Drain cross-machine messages for a session")
    p.add_argument("--uid", required=True)

    p = sub.add_parser(
        "resume-check", help="Show what changed since this session was last seen"
    )
    p.add_argument("--uid", required=True)

    sub.add_parser("install", help="Install hooks into Claude Code")
    sub.add_parser("uninstall", help="Remove hooks from Claude Code")

    args = parser.parse_args()

    # Dispatch
    if args.command == "hook":
        hook_handlers = {
            "prompt": hook_prompt,
            "pre-tool": hook_pre_tool,
            "post-tool": hook_post_tool,
            "start": hook_start,
            "stop": hook_stop,
        }
        handler = hook_handlers.get(args.event)
        if handler:
            try:
                handler(args)
            except Exception as e:
                # Hooks must never crash — fail silently rather than
                # block the user's prompt or tool call
                print(f"[claustrum error: {e}]", file=sys.stderr)
        else:
            hook_p.print_help()

    elif args.command == "checkin":
        cmd_checkin(args)
    elif args.command == "heartbeat":
        cmd_heartbeat(args)
    elif args.command == "update":
        cmd_update(args)
    elif args.command == "topics":
        cmd_topics(args)
    elif args.command == "domains":
        cmd_domains(args)
    elif args.command == "classify-self":
        cmd_classify_self(args)
    elif args.command == "propose-topic":
        cmd_propose_topic(args)
    elif args.command == "propose-domain":
        cmd_propose_domain(args)
    elif args.command == "send":
        cmd_send(args)
    elif args.command == "claim":
        cmd_claim(args)
    elif args.command == "release":
        cmd_release(args)
    elif args.command == "done":
        cmd_done(args)
    elif args.command == "status":
        cmd_status(args)
    elif args.command == "show":
        cmd_show(args)
    elif args.command == "archive":
        cmd_archive(args)
    elif args.command == "gc":
