#!/usr/bin/env python3
"""
Claustrum — Unconscious coordination layer for Claude Code sessions.

Named after the brain structure that coordinates activity across cortical
regions. Like its biological counterpart, Claustrum provides shared awareness
between independent Claude Code sessions without requiring conscious
coordination.

Architecture:
  - SQLite (WAL mode) as the coordination store
  - Claude Code hooks for involuntary integration
  - No daemon needed — direct DB access from each session

Hook integration:
  UserPromptSubmit  → claustrum hook prompt     (heartbeat + context injection)
  PreToolUse        → claustrum hook pre-tool   (file claim enforcement)
  PostToolUse       → claustrum hook post-tool  (change broadcast)
  SessionStart      → claustrum hook start      (session registration)
  SessionEnd        → claustrum hook stop       (session cleanup)
"""

import argparse
import json
import os
import socket
import sqlite3
import subprocess
import sys
import time
from pathlib import Path
from urllib import request as _urlrequest
from urllib import parse as _urlparse
from urllib import error as _urlerror

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

DB_DIR = Path.home() / ".claustrum"
DB_PATH = DB_DIR / "state.db"
STALE_SECONDS = 432000   # 5 days without heartbeat = stale
CLEANUP_SECONDS = 432000 # 5 days = remove done/stale sessions

# Cloud client (optional cross-machine layer)
#   CLOUD_TIMEOUT             — background/hook calls. Tight so a slow or cold
#                               server never delays the user's prompt; hooks
#                               fail open to local SQLite.
#   CLOUD_TIMEOUT_INTERACTIVE — foreground subcommands the agent/user runs and
#                               waits on (classify-self, propose-topic, the
#                               manual update/checkin/reset). A cold IAP LB can
#                               take a few seconds; failing those at 1.5s would
#                               wrongly report "failed" for a call that just
#                               needed warmup.
CLOUD_TIMEOUT = 1.5
CLOUD_TIMEOUT_INTERACTIVE = 8.0
_banner_printed = False
_IS_HOOK_INVOCATION = (len(sys.argv) >= 2 and sys.argv[1] == "hook")

# ---------------------------------------------------------------------------
# Cloud client — optional cross-machine coordination layer
#
# Activated when CLAUSTRUM_CLOUD_URL is set. All cloud calls are best-effort:
# any failure (network, auth, 5xx, missing server route) is swallowed and the
# caller falls back to local-only behavior. Cloud must never block local work.
#
# Privacy gate (see .context/claustrum-privacy-design.md):
#   CLAUSTRUM_PRIVATE=1   no cloud calls at all; loud banner on stderr
#   CLAUSTRUM_PUBLIC=1    overrides PRIVATE (the LLM was too cautious)
#   --private flag        same effect as CLAUSTRUM_PRIVATE for one invocation
#
# Auth strategy — pluggable for different reverse-proxies (IAP, Cloudflare
# Access, Authelia, Tailscale, etc):
#   CLAUSTRUM_AUTH_HEADER   default "Authorization"
#   CLAUSTRUM_AUTH_VALUE    static header value
#   CLAUSTRUM_AUTH_COMMAND  shell command whose stdout becomes the header
#                           value (preferred for short-lived tokens — the
#                           command runs per request, so a thin wrapper can
#                           cache + refresh tokens transparently)
# ---------------------------------------------------------------------------

def _cloud_url():
    return os.environ.get("CLAUSTRUM_CLOUD_URL", "").strip() or None


def _privacy_mode(force_private=False):
    """Resolve effective privacy. force_private wins, then PUBLIC, then PRIVATE."""
    if force_private:
        return True
    if os.environ.get("CLAUSTRUM_PUBLIC", "").strip() == "1":
        return False
    return os.environ.get("CLAUSTRUM_PRIVATE", "").strip() == "1"


def _print_private_banner_once():
    """Print the privacy banner once per process. Suppressed in hook mode so
    background hook events don't spam stderr / Claude Code session logs."""
    global _banner_printed
    if _banner_printed or _IS_HOOK_INVOCATION:
        return
    _banner_printed = True
    if "--private" in sys.argv:
        trigger = "--private flag"
    else:
        trigger = "CLAUSTRUM_PRIVATE=1"
    sys.stderr.write(
        "┌" + "─" * 63 + "┐\n"
        + "│ \U0001f512 PRIVATE SESSION" + " " * 44 + "│\n"
        + "│ This session is NOT being published to claustrum.finder.com.  │\n"
        + "│ Trigger: " + trigger.ljust(53) + "│\n"
        + "└" + "─" * 63 + "┘\n"
    )
    sys.stderr.flush()


def _resolve_auth():
    """Return (header_name, header_value) or None if no auth configured."""
    header = os.environ.get("CLAUSTRUM_AUTH_HEADER", "").strip() or "Authorization"
    cmd = os.environ.get("CLAUSTRUM_AUTH_COMMAND", "").strip()
    if cmd:
        try:
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True, timeout=10,
            )
            value = result.stdout.strip()
            if value:
                return header, value
        except Exception:
            return None
        return None
    value = os.environ.get("CLAUSTRUM_AUTH_VALUE", "").strip()
    if value:
        return header, value
    return None


def _should_cloud_send(force_private=False):
    """Return True iff a cloud HTTP call should be attempted."""
    if not _cloud_url():
        return False
    if _privacy_mode(force_private):
        _print_private_banner_once()
        return False
    return True


def _cloud_request(method, path, body=None, params=None, timeout=None):
    """Synchronous best-effort HTTP request. Returns dict on success, None
    on any failure. Caller has already gated on _should_cloud_send."""
    url = _cloud_url()
    if not url:
        return None
    full = url.rstrip("/") + path
    if params:
        clean = {k: v for k, v in params.items() if v is not None}
        if clean:
            full += "?" + _urlparse.urlencode(clean)
    data = None
    headers = {"Accept": "application/json"}
    if body is not None:
        data = json.dumps(body).encode("utf-8")
        headers["Content-Type"] = "application/json"
    auth = _resolve_auth()
    if auth:
        headers[auth[0]] = auth[1]
    req = _urlrequest.Request(full, data=data, headers=headers, method=method)
    try:
        with _urlrequest.urlopen(req, timeout=timeout or CLOUD_TIMEOUT) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            return json.loads(raw) if raw else {}
    except Exception:
        return None


def _git_info(cwd):
    """Best-effort: derive (repo_name, branch) from a directory via git."""
    repo = None
    branch = None
    target = cwd or os.getcwd()
    try:
        result = subprocess.run(
            ["git", "-C", target, "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=1,
        )
        if result.returncode == 0:
            repo = os.path.basename(result.stdout.strip()) or None
    except Exception:
        pass
    try:
        result = subprocess.run(
            ["git", "-C", target, "branch", "--show-current"],
            capture_output=True, text=True, timeout=1,
        )
        if result.returncode == 0:
            branch = result.stdout.strip() or None
    except Exception:
        pass
    return repo, branch


def _cloud_checkin(uid, task=None, cwd=None, label=None, force_private=False,
                   timeout=None):
    """Best-effort write-through to POST /v1/checkin. Returns the parsed
    response dict (so callers can read topic_required / taxonomy /
    first_turn_message) or None on any failure / privacy suppression.

    PRIVACY (v2): `task` should be a COARSE label only — never the raw user
    prompt. The turn-1 leak in v1 came from publishing the first 200 chars of
    the prompt here. The detail layer (what's actually being worked on) goes
    through /v1/update with a value-scrubbed `working_on`, not through checkin.
    """
    if not _should_cloud_send(force_private):
        return None
    repo, branch = _git_info(cwd)
    body = {
        "uid": uid,
        "machine": socket.gethostname() or "unknown",
        "label": label or _get_session_label(),
        "task": task,
        "repo": repo,
        "branch": branch,
        "cwd": cwd,
        "is_quiet": _IS_HOOK_INVOCATION,
        "is_private": False,
    }
    return _cloud_request("POST", "/v1/checkin", body=body, timeout=timeout)


def _cloud_reset(force_private=False):
    """Best-effort POST /v1/reset. Returns dict on success, None on failure
    (including server 501)."""
    if not _should_cloud_send(force_private):
        return None
    return _cloud_request("POST", "/v1/reset", body={}, timeout=CLOUD_TIMEOUT_INTERACTIVE)


def _cloud_list_peers(uid, repo=None, topic=None, files_touched=None):
    """Best-effort GET /v1/list (v2 tiered-overlap dedup). Returns the `tiers`
    dict or None.

    Shape (see cloud/server/app/routes/list_peers.py):
        {
          "t1_file_overlap": [peer, ...],          # same repo + ≥1 exact file
          "t2_path_or_pr":   [peer, ...],          # same repo + same PR / dir
          "t3_topic":        {topic, count, peers},
          "t4_repo":         {repo,  count, peers},
        }
    Any dimension the client omits the server fills from the session's stored
    state (repo / topic / files / pr_number), so passing just `uid` works once
    the detail layer has been fed via /v1/update.
    """
    if not _should_cloud_send():
        return None
    params = {"uid": uid, "repo": repo, "topic": topic}
    if files_touched:
        params["files_touched"] = ",".join(files_touched)
    resp = _cloud_request("GET", "/v1/list", params=params)
    if isinstance(resp, dict) and isinstance(resp.get("tiers"), dict):
        return resp["tiers"]
    return None


def _cloud_update(uid, task=None, working_on=None, files_touched=None,
                  pr_number=None, last_push_at=None, status=None,
                  force_private=False, timeout=None):
    """Best-effort POST /v1/update — the detail layer. Only non-None fields are
    sent; the server COALESCE-merges them and *unions* files_touched into the
    existing set (so incremental single-file pushes never clobber earlier
    ones). Returns the parsed dict or None.

    `working_on` must be value-scrubbed (describes the work, never a raw secret
    / token / PII) — the privacy contract for the cloud-resident detail layer.
    """
    if not _should_cloud_send(force_private):
        return None
    body = {"uid": uid}
    if task is not None:
        body["task"] = task
    if working_on is not None:
        body["working_on"] = working_on
    if files_touched:
        body["files_touched"] = files_touched
    if pr_number is not None:
        body["pr_number"] = pr_number
    if last_push_at is not None:
        body["last_push_at"] = last_push_at
    if status is not None:
        body["status"] = status
    return _cloud_request("POST", "/v1/update", body=body, timeout=timeout)


def _cloud_classify_self(uid, topic, confidence=80, force_private=False):
    """Best-effort POST /v1/classify_self — set the session's topic and get back
    historical_dedupe (active_peers + related_prs). Returns dict or None."""
    if not _should_cloud_send(force_private):
        return None
    return _cloud_request(
        "POST", "/v1/classify_self",
        body={"uid": uid, "topic": topic, "confidence": confidence},
        timeout=CLOUD_TIMEOUT_INTERACTIVE,
    )


def _cloud_propose_topic(uid, name, description, force_private=False):
    """Best-effort POST /v1/propose_topic — queue a new topic into the emergent
    taxonomy. Returns dict (distinct_user_count / promotion_threshold /
    promotable) or None."""
    if not _should_cloud_send(force_private):
        return None
    return _cloud_request(
        "POST", "/v1/propose_topic",
        body={"uid": uid, "name": name, "description": description},
        timeout=CLOUD_TIMEOUT_INTERACTIVE,
    )


# ---------------------------------------------------------------------------
# Detail-layer derivation — repo-relative paths + git/gh metadata
#
# The cloud dedup engine intersects files_touched as a SET across machines, so
# paths MUST be repo-relative (two people on the same file have identical rel
# paths but different absolute ones). pr_number/last_push_at let the server
# bucket peers into the t2 "same PR" tier.
# ---------------------------------------------------------------------------

def _rel_to_repo(filepath, cwd=None):
    """Return `filepath` relative to its git toplevel, for cross-machine set
    overlap. Falls back to the basename if the file isn't inside a repo."""
    if not filepath:
        return None
    target = os.path.dirname(filepath) or (cwd or os.getcwd())
    try:
        result = subprocess.run(
            ["git", "-C", target, "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=1,
        )
        if result.returncode == 0:
            top = result.stdout.strip()
            if top:
                try:
                    return os.path.relpath(os.path.abspath(filepath), top)
                except ValueError:
                    pass
    except Exception:
        pass
    return os.path.basename(filepath)


def _git_last_push_at(target):
    """Best-effort ISO timestamp approximating the last push: commit date of the
    upstream-tracked HEAD (@{push}), falling back to HEAD's commit date. Local
    and fast — no network."""
    target = target or os.getcwd()
    for ref in ("@{push}", "HEAD"):
        try:
            result = subprocess.run(
                ["git", "-C", target, "log", "-1", "--format=%cI", ref],
                capture_output=True, text=True, timeout=1,
            )
            if result.returncode == 0 and result.stdout.strip():
                return result.stdout.strip()
        except Exception:
            pass
    return None


_PR_CACHE_PATH = DB_DIR / "pr-cache.json"
_PR_CACHE_TTL = 300  # seconds — re-query gh at most once per 5 min per branch


def _get_pr_number(target, repo, branch):
    """Best-effort current-branch PR number via `gh`, cached per (repo, branch)
    with a TTL so it isn't re-queried on every edit. Caches negative results
    too (a branch with no PR shouldn't trigger a gh call every keystroke).
    Returns int or None."""
    if not repo or not branch:
        return None
    key = f"{repo}:{branch}"
    now = time.time()

    cache = {}
    try:
        if _PR_CACHE_PATH.exists():
            cache = json.loads(_PR_CACHE_PATH.read_text())
    except Exception:
        cache = {}

    entry = cache.get(key)
    if isinstance(entry, dict) and (now - entry.get("ts", 0)) < _PR_CACHE_TTL:
        return entry.get("pr")

    pr = None
    try:
        result = subprocess.run(
            ["gh", "pr", "view", "--json", "number", "-q", ".number"],
            cwd=target or os.getcwd(),
            capture_output=True, text=True, timeout=3,
        )
        if result.returncode == 0 and result.stdout.strip().isdigit():
            pr = int(result.stdout.strip())
    except Exception:
        pr = None

    cache[key] = {"pr": pr, "ts": now}
    try:
        DB_DIR.mkdir(parents=True, exist_ok=True)
        _PR_CACHE_PATH.write_text(json.dumps(cache))
    except Exception:
        pass
    return pr


# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

def get_db():
    """Get a database connection with WAL mode and schema initialized."""
    DB_DIR.mkdir(parents=True, exist_ok=True)
    db = sqlite3.connect(str(DB_PATH), timeout=5)
    db.row_factory = sqlite3.Row
    db.execute("PRAGMA journal_mode=WAL")
    db.execute("PRAGMA busy_timeout=5000")
    _init_schema(db)
    return db


def _init_schema(db):
    db.executescript("""
        CREATE TABLE IF NOT EXISTS sessions (
            uid          TEXT PRIMARY KEY,
            label        TEXT,
            task         TEXT,
            working_on   TEXT,
            status       TEXT DEFAULT 'active',
            cwd          TEXT,
            last_seen    REAL NOT NULL,
            started_at   REAL NOT NULL
        );

        CREATE TABLE IF NOT EXISTS messages (
            id           INTEGER PRIMARY KEY AUTOINCREMENT,
            from_uid     TEXT,
            to_uid       TEXT,
            type         TEXT NOT NULL DEFAULT 'info',
            body         TEXT NOT NULL,
            created_at   REAL NOT NULL,
            read_at      REAL
        );

        CREATE TABLE IF NOT EXISTS claims (
            filepath     TEXT NOT NULL,
            uid          TEXT NOT NULL,
            claimed_at   REAL NOT NULL,
            PRIMARY KEY (filepath, uid)
        );

        CREATE INDEX IF NOT EXISTS idx_messages_to
            ON messages(to_uid, read_at);
        CREATE INDEX IF NOT EXISTS idx_claims_file
            ON claims(filepath);
        CREATE INDEX IF NOT EXISTS idx_sessions_status
            ON sessions(status);
    """)
    db.commit()


def _clean_stale(db, now):
    """Mark stale sessions and release their claims. Returns count."""
    threshold = now - STALE_SECONDS
    stale = db.execute(
        "SELECT uid FROM sessions WHERE last_seen < ? AND status = 'active'",
        (threshold,)
    ).fetchall()

    for s in stale:
        db.execute(
            "UPDATE sessions SET status = 'stale' WHERE uid = ?",
            (s["uid"],)
        )
        db.execute("DELETE FROM claims WHERE uid = ?", (s["uid"],))

    # Purge old done/stale sessions and read messages
    old = now - CLEANUP_SECONDS
    db.execute(
        "DELETE FROM sessions WHERE last_seen < ? AND status IN ('stale','done')",
        (old,),
    )
    db.execute(
        "DELETE FROM messages WHERE read_at IS NOT NULL AND read_at < ?",
        (old,),
    )

    return len(stale)


def _get_session_label():
    """Get a human-readable label for this terminal session.

    Fallback chain (first non-empty wins):
      1. CLAUSTRUM_LABEL env var (explicit override)
      2. tmux pane title (if inside tmux)
      3. iTerm2 tab name (macOS)
      4. Terminal.app window name (macOS)
      5. basename of working directory
    """
    # 1. Explicit override
    label = os.environ.get("CLAUSTRUM_LABEL", "").strip()
    if label:
        return label

    # 2. tmux session name (the slug set via tmux rename-session)
    try:
        pane = os.environ.get("TMUX_PANE")
        if pane:
            result = subprocess.run(
                ["tmux", "display-message", "-t", pane, "-p", "#{session_name}"],
                capture_output=True, text=True, timeout=2,
            )
            name = result.stdout.strip()
            if name:
                return name
    except Exception:
        pass

    # 3. iTerm2 tab name (only if iTerm2 is already running)
    # 4. Terminal.app window name (only if Terminal is already running)
    # `tell application "X"` launches X if not running, so guard with
    # System Events process check (does not launch the app).
    for app, query in (
        ("iTerm2", 'tell application "iTerm2" to get name of current tab of current window'),
        ("Terminal", 'tell application "Terminal" to get name of front window'),
    ):
        try:
            check = subprocess.run(
                ["osascript", "-e",
                 f'tell application "System Events" to (name of processes) contains "{app}"'],
                capture_output=True, text=True, timeout=2,
            )
            if check.stdout.strip().lower() != "true":
                continue
            result = subprocess.run(
                ["osascript", "-e", query],
                capture_output=True, text=True, timeout=2,
            )
            name = result.stdout.strip()
            if name and result.returncode == 0:
                return name
        except Exception:
            pass

    # 5. Directory basename as last resort
    return os.path.basename(os.getcwd())


def _clean_label(label):
    """Strip leading status indicators (braille, emoji, symbols) from labels.

    Pane titles may already contain status indicators from other tools
    (e.g. statusline). Strip them so Claustrum can prepend its own.
    """
    import re
    # Strip leading braille patterns (U+2800-U+28FF), common symbols, and whitespace
    return re.sub(r'^[\u2800-\u28FF✳◇◆●○■□▪▫★☆⚡🤖\s]+', '', label).strip()


def _ensure_session(db, uid, cwd=None):
    """Register or refresh a session."""
    now = time.time()
    label = _get_session_label()
    db.execute(
        """
        INSERT INTO sessions (uid, label, status, cwd, last_seen, started_at)
        VALUES (?, ?, 'active', ?, ?, ?)
        ON CONFLICT(uid) DO UPDATE SET
            label = COALESCE(?, label),
            status = 'active',
            cwd = COALESCE(?, cwd),
            last_seen = ?
        """,
        (uid, label, cwd, now, now, label, cwd, now),
    )


def _format_ago(seconds):
    s = int(seconds)
    if s < 60:
        return f"{s}s ago"
    if s < 3600:
        return f"{s // 60}m ago"
    return f"{s // 3600}h ago"


def _short_email(email):
    """`joe.waller@finder.com` -> `joe.waller` for compact peer lines."""
    if not email:
        return "someone"
    return email.split("@", 1)[0]


def _render_cloud_tiers(tiers):
    """Render the /v1/list tiered-overlap result for the heartbeat tray. t1/t2
    are collisions (someone is on YOUR files / PR) and get surfaced loudly;
    t3/t4 are softer "also in this topic/repo" counts. Returns a list of lines
    (empty if nothing worth showing)."""
    if not isinstance(tiers, dict):
        return []

    t1 = tiers.get("t1_file_overlap") or []
    t2 = tiers.get("t2_path_or_pr") or []
    t3 = tiers.get("t3_topic") or {}
    t4 = tiers.get("t4_repo") or {}

    lines = []

    if t1:
        lines.append("  ⚠️  CROSS-MACHINE FILE COLLISION — someone is already editing your files:")
        for p in t1:
            who = _short_email(p.get("user_email"))
            files = ", ".join(p.get("overlap_files") or []) or "?"
            on = p.get("working_on") or p.get("topic") or "-"
            lines.append(f"      • {who} ({p.get('machine','?')}): {files}  — {on}")

    if t2:
        lines.append("  ⚠️  Same PR / directory as you:")
        for p in t2:
            who = _short_email(p.get("user_email"))
            reason = p.get("reason") or ""
            on = p.get("working_on") or p.get("topic") or "-"
            lines.append(f"      • {who} ({p.get('machine','?')}) [{reason}] — {on}")

    if isinstance(t3, dict) and t3.get("count"):
        topic = t3.get("topic") or "?"
        peers = ", ".join(
            _short_email(p.get("user_email")) for p in (t3.get("peers") or [])
        )
        extra = f" ({peers})" if peers else ""
        lines.append(f"  · {t3['count']} other session(s) on topic '{topic}'{extra}")

    if isinstance(t4, dict) and t4.get("count"):
        repo = t4.get("repo") or "?"
        lines.append(f"  · {t4['count']} other session(s) in repo '{repo}'")

    if lines:
        lines.insert(0, "Cross-machine (claustrum cloud):")
    return lines


def _build_classify_block(uid, checkin_resp):
    """If the cloud says this session is untagged, build the context block that
    tells the agent to classify itself from the emergent taxonomy. Returns a
    list of lines (empty if not required)."""
    if not isinstance(checkin_resp, dict) or not checkin_resp.get("topic_required"):
        return []
    lines = ["Claustrum: this session has no topic yet. On your NEXT response, classify it:"]
    taxonomy = checkin_resp.get("taxonomy") or []
    if taxonomy:
        lines.append("  Existing topics (pick the best fit):")
        for t in taxonomy[:30]:
            desc = (t.get("description") or "").strip()
            desc = f" — {desc}" if desc else ""
            lines.append(f"    • {t.get('name')}{desc}")
        lines.append(f"  Run:  claustrum classify-self {uid} \"<topic>\"")
        lines.append(
            f"  If none fit:  claustrum propose-topic {uid} \"<name>\" \"<short description>\""
        )
    else:
        lines.append(
            "  Taxonomy is empty — mint one:  "
            f"claustrum propose-topic {uid} \"<name>\" \"<short description>\""
        )
        lines.append(
            f"  then  claustrum classify-self {uid} \"<name>\"  to tag this session."
        )
    return lines


# ---------------------------------------------------------------------------
# Hook handlers  (read JSON from stdin, interact with DB, write to stdout)
#
# IMPORTANT: hooks must never crash. A broken hook blocks the user's prompt.
# Every handler is wrapped in try/except at the dispatch level.
# ---------------------------------------------------------------------------

def hook_prompt(_args):
    """UserPromptSubmit — heartbeat, read messages, inject context."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    cwd = data.get("cwd")
    prompt = (data.get("prompt") or "")[:200]  # first 200 chars

    db = get_db()
    now = time.time()

    _ensure_session(db, uid, cwd)

    # Auto-set task from user's prompt LOCALLY so same-machine sessions see
    # intent. This stays in SQLite and NEVER leaves the machine.
    if prompt:
        db.execute(
            "UPDATE sessions SET task = ? WHERE uid = ?",
            (prompt, uid),
        )

    # Best-effort cloud write-through. PRIVACY (v2): the raw prompt is NOT sent
    # — only the coarse `label` (tmux slug, derived inside _cloud_checkin) goes
    # up, killing the v1 turn-1 leak. The response tells us whether the session
    # still needs a topic so the agent can self-classify. Privacy gate honors
    # CLAUSTRUM_PRIVATE / CLAUSTRUM_PUBLIC internally.
    checkin_resp = _cloud_checkin(uid, task=None, cwd=cwd)

    # Unread messages for this session (or broadcasts), excluding own
    messages = db.execute(
        """
        SELECT from_uid, type, body, created_at FROM messages
        WHERE (to_uid = ? OR to_uid IS NULL)
          AND read_at IS NULL
          AND from_uid != ?
        ORDER BY created_at
        """,
        (uid, uid),
    ).fetchall()

    if messages:
        db.execute(
            """
            UPDATE messages SET read_at = ?
            WHERE (to_uid = ? OR to_uid IS NULL)
              AND read_at IS NULL
              AND from_uid != ?
            """,
            (now, uid, uid),
        )

    # Other sessions (active and stale — stale just means idle, not exited)
    others = db.execute(
        """
        SELECT uid, label, task, working_on, status, last_seen, cwd FROM sessions
        WHERE uid != ? AND status IN ('active', 'stale')
        ORDER BY last_seen DESC
        """,
        (uid,),
    ).fetchall()

    db.commit()
    db.close()

    # Cross-machine layer (best-effort, silent on failure / privacy / offline).
    # Server fills repo/topic/files/pr from this session's stored state.
    cloud_lines = _render_cloud_tiers(_cloud_list_peers(uid))
    classify_lines = _build_classify_block(uid, checkin_resp)

    # Only output if there's something worth reporting (local OR cloud).
    if not messages and not others and not cloud_lines and not classify_lines:
        if data.get("hook_event_name") == "BeforeAgent":
            print("{}")
        return

    parts = []
    n = len(others)
    parts.append(f"[Claustrum \u2014 {n} other session{'s' if n != 1 else ''}]")

    for o in others:
        ago = _format_ago(now - o["last_seen"])
        name = _clean_label(o["label"]) if o["label"] else o["uid"][:12]
        # ⠂ = active (recent heartbeat), ⠐ = idle (no recent heartbeat)
        indicator = "\u2802" if o["status"] == "active" else "\u2810"
        parts.append("")
        parts.append(f"  {indicator} {name} ({ago}):")
        if o["task"]:
            parts.append(f"    Task: {o['task']}")
        if o["working_on"]:
            parts.append(f"    Working on: {o['working_on']}")
        # Dir omitted to save tokens — almost always the same

    if cloud_lines:
        parts.append("")
        parts.extend(cloud_lines)

    if messages:
        parts.append("")
        parts.append("Messages:")
        for m in messages:
            sender = m["from_uid"][:12] if m["from_uid"] else "system"
            parts.append(f"  \u2022 [{m['type']}] {sender}: {m['body']}")

    if classify_lines:
        parts.append("")
        parts.extend(classify_lines)

    output = "\n".join(parts)
    if output.strip():
        if data.get("hook_event_name") == "BeforeAgent":
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": "BeforeAgent",
                    "additionalContext": output
                }
            }))
        else:
            print(output)


def hook_pre_tool(_args):
    """PreToolUse — enforce file claims for Edit/Write."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    tool_name = data.get("tool_name", "")
    tool_input = data.get("tool_input", {})

    if tool_name not in ("Edit", "Write"):
        return

    filepath = tool_input.get("file_path", "")
    if not filepath:
        return

    db = get_db()
    now = time.time()

    _ensure_session(db, uid)

    # Check for conflicting claim
    conflict = db.execute(
        """
        SELECT c.uid, s.task FROM claims c
        JOIN sessions s ON c.uid = s.uid
        WHERE c.filepath = ? AND c.uid != ? AND s.status = 'active'
        """,
        (filepath, uid),
    ).fetchone()

    if conflict:
        db.close()
        task_info = f" (task: {conflict['task']})" if conflict["task"] else ""
        print(
            f"Claustrum: {filepath} is claimed by session "
            f"{conflict['uid'][:12]}{task_info}. "
            f"Coordinate before editing. Use: "
            f"claustrum send --uid <your-uid> --to {conflict['uid']} "
            f'--body "requesting access to {os.path.basename(filepath)}"',
            file=sys.stderr,
        )
        sys.exit(2)

    # Claim the file
    db.execute(
        "INSERT OR REPLACE INTO claims (filepath, uid, claimed_at) VALUES (?,?,?)",
        (filepath, uid, now),
    )
    db.commit()
    db.close()


def hook_post_tool(_args):
    """PostToolUse — broadcast file changes to other sessions."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    tool_name = data.get("tool_name", "")
    tool_input = data.get("tool_input", {})

    if tool_name not in ("Edit", "Write"):
        return

    filepath = tool_input.get("file_path", "")
    if not filepath:
        return

    db = get_db()
    now = time.time()

    # Only broadcast if someone else is listening
    others = db.execute(
        "SELECT COUNT(*) as cnt FROM sessions WHERE uid != ? AND status = 'active'",
        (uid,),
    ).fetchone()

    if others["cnt"] > 0:
        db.execute(
            """
            INSERT INTO messages (from_uid, to_uid, type, body, created_at)
            VALUES (?, NULL, 'file-change', ?, ?)
            """,
            (uid, f"Edited {filepath}", now),
        )

    db.commit()
    db.close()

    # Feed the cloud detail layer: repo-relative file (for cross-machine t1/t2
    # set overlap) plus pr_number (cached gh) + last_push_at (local git). This
    # is the activity-bearing path — the per-turn hook stays lean. Best-effort;
    # privacy gate honors CLAUSTRUM_PRIVATE / CLAUSTRUM_PUBLIC.
    target = os.path.dirname(filepath) or data.get("cwd") or os.getcwd()
    rel = _rel_to_repo(filepath, data.get("cwd"))
    repo, branch = _git_info(target)
    _cloud_update(
        uid,
        files_touched=[rel] if rel else None,
        pr_number=_get_pr_number(target, repo, branch),
        last_push_at=_git_last_push_at(target),
    )


def hook_start(_args):
    """SessionStart — register this session."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    cwd = data.get("cwd")

    db = get_db()
    now = time.time()
    _ensure_session(db, uid, cwd)
    db.commit()

    # Best-effort cloud announcement
    _cloud_checkin(uid, cwd=cwd)

    others = db.execute(
        "SELECT COUNT(*) as cnt FROM sessions WHERE uid != ? AND status = 'active'",
        (uid,),
    ).fetchone()
    db.close()

    if others["cnt"] > 0:
        msg = f"[Claustrum] Session registered. {others['cnt']} other active session(s)."
        if data.get("hook_event_name") == "SessionStart":
            print(json.dumps({"systemMessage": msg}))
        else:
            print(msg)
    else:
        if data.get("hook_event_name") == "SessionStart":
            print("{}")


def hook_stop(_args):
    """SessionEnd — mark session done, release all claims."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")

    db = get_db()
    now = time.time()
    db.execute(
        "UPDATE sessions SET status = 'done', last_seen = ? WHERE uid = ?",
        (now, uid),
    )
    db.execute("DELETE FROM claims WHERE uid = ?", (uid,))
    db.commit()
    db.close()


