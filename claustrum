def _cloud_claim(uid, repo, rel_path, ttl_seconds=3600, force_private=False):
    """Best-effort POST /v1/claim — a cross-machine soft claim (TTL'd, never a
    hard lock). Returns the dict (claimed + conflicts) or None. repo/rel_path
    must be set (cross-machine overlap keys on repo-relative paths)."""
    if not _should_cloud_send(force_private) or not (repo and rel_path):
        return None
    return _cloud_request(
        "POST", "/v1/claim",
        body={"uid": uid, "repo": repo, "rel_path": rel_path,
              "ttl_seconds": ttl_seconds},
        timeout=CLOUD_TIMEOUT_INTERACTIVE,
    )


