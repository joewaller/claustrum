DB_DIR = Path.home() / ".claustrum"
DB_PATH = DB_DIR / "state.db"
STALE_SECONDS = 432000   # 5 days without heartbeat = stale
CLEANUP_SECONDS = 432000 # 5 days = remove done/stale sessions

# Heartbeat-tray display tuning. The session store keeps everything for up to
# CLEANUP_SECONDS, but dumping all of it (with each session's task + working_on)
# into every UserPromptSubmit is thousands of tokens per turn. The tray is just
# an at-a-glance "who else is around" — so cap the list, show one line each, and
# only spend the extra detail on GENUINE collisions (sessions editing files this
# session has claimed). `claustrum status` still shows the full picture.
DISPLAY_MAX_SESSIONS = 8        # cap the one-line session list; rest collapse to "+N more"
DISPLAY_RECENT_SECONDS = 3600   # only list sessions seen within the last hour
# Above this many sessions sharing your cwd, it's the monorepo root (everyone
# lives under ~/projects), not a genuine clash — so suppress the hint.
DISPLAY_CLASH_MAX = 4

# Cloud client (optional cross-machine layer)
#   CLOUD_TIMEOUT             — background/hook calls. Tight so a slow or cold
#                               server never delays the user's prompt; hooks
#                               fail open to local SQLite.
#   CLOUD_TIMEOUT_INTERACTIVE — foreground subcommands the agent/user runs and
#                               waits on (classify-self, propose-topic, the
#                               manual update/checkin/reset). A cold IAP LB can
#                               take a few seconds; failing those at 1.5s would
#                               wrongly report "failed" for a call that just
#                               needed warmup.
CLOUD_TIMEOUT = 1.5
CLOUD_TIMEOUT_INTERACTIVE = 8.0

# Phase-2 classify directive tuning. A deliberate sub-agent/human classify-self
# writes confidence 80; the local keyword heuristic caps at 60 and the tick floor
# is 20-25. CLASSIFY_CONF_FLOOR is the line below which a session is considered
# not-yet-confidently-classified, so the directive keeps asking for a real
# domain+topic. CLASSIFY_MAX_NUDGES bounds how many turns an ignoring agent is
# nudged before Claustrum goes quiet (the tick floor still guarantees coverage).
CLASSIFY_CONF_FLOOR = 70
CLASSIFY_MAX_NUDGES = 1  # fire the sub-agent directive ONCE (no nagging); the
                         # heartbeat backstop covers a session that ignores it.
# Don't classify on turn 1 — that's just the opening intent (the stale-name
# trap). By turn 2 the first turn's work is back and the agent's context reflects
# the session's real subject, so the directive fires from turn 2 onward.
CLASSIFY_MIN_TURN = 2
# Optional headless backstop: if CLAUSTRUM_CLASSIFY_CMD is set, that external
# command (any LLM CLI — never hardcoded to claude) classifies a session the
# in-session sub-agent directive didn't, reading the full transcript. It fires
# ONCE per session from the heartbeat tick (not per turn — we don't want an LLM
# call every turn), so the timeout can be generous. Falls back to the keyword
# heuristic on timeout/error. Backstop confidence sits below a deliberate pick.
CLASSIFY_CMD_TIMEOUT = 30
CLASSIFY_BACKSTOP_CONF = 78
# How much transcript the backstop hands its classifier. The default tail (6000
# chars) is enough for the per-turn heuristic but too thin for the once-per-session
# LLM backstop — a coarse 'gateway'/'gcp' bucket survives because the model never
# sees what the session is really about. The backstop fires once and uses a cheap
# model, so a generous bound (≈ whole chat for most sessions) is affordable; still
# capped so a marathon session can't blow the model's context window.
CLASSIFY_BACKSTOP_CHARS = 40000
# Bounded retries for the backstop: a transient model blip (empty/garbled output)
# must NOT permanently disable it. backstop_done counts attempts — retry across
# ticks up to this many, then give up; a success jumps straight to the cap.
CLASSIFY_BACKSTOP_ATTEMPTS = 3
# Reclassify-on-drift: once a session is confidently classified, re-surface its
# current topic+domain every DRIFT_CADENCE turns (capped at DRIFT_MAX_NUDGES) so
# the agent can self-correct if the work has drifted to a different subject.
DRIFT_CADENCE = 15
DRIFT_MAX_NUDGES = 2
_banner_printed = False
_IS_HOOK_INVOCATION = (len(sys.argv) >= 2 and sys.argv[1] == "hook")

# ---------------------------------------------------------------------------
# Cloud client — optional cross-machine coordination layer
#
# Activated when CLAUSTRUM_CLOUD_URL is set. All cloud calls are best-effort:
# any failure (network, auth, 5xx, missing server route) is swallowed and the
# caller falls back to local-only behavior. Cloud must never block local work.
#
# Privacy gate (see .context/claustrum-privacy-design.md):
#   CLAUSTRUM_PRIVATE=1   no cloud calls at all; loud banner on stderr
#   CLAUSTRUM_PUBLIC=1    overrides PRIVATE (the LLM was too cautious)
#   --private flag        same effect as CLAUSTRUM_PRIVATE for one invocation
#
# Auth strategy — pluggable for different reverse-proxies (IAP, Cloudflare
# Access, Authelia, Tailscale, etc):
#   CLAUSTRUM_AUTH_HEADER   default "Authorization"
#   CLAUSTRUM_AUTH_VALUE    static header value
#   CLAUSTRUM_AUTH_COMMAND  shell command whose stdout becomes the header
#                           value (preferred for short-lived tokens — the
#                           command runs per request, so a thin wrapper can
#                           cache + refresh tokens transparently)
# ---------------------------------------------------------------------------

def _cloud_url():
    return os.environ.get("CLAUSTRUM_CLOUD_URL", "").strip() or None


def _privacy_mode(force_private=False):
    """Resolve effective privacy. force_private wins, then PUBLIC, then PRIVATE."""
    if force_private:
        return True
    if os.environ.get("CLAUSTRUM_PUBLIC", "").strip() == "1":
        return False
    return os.environ.get("CLAUSTRUM_PRIVATE", "").strip() == "1"


def _print_private_banner_once():
    """Print the privacy banner once per process. Suppressed in hook mode so
    background hook events don't spam stderr / Claude Code session logs."""
    global _banner_printed
    if _banner_printed or _IS_HOOK_INVOCATION:
        return
    _banner_printed = True
    if "--private" in sys.argv:
        trigger = "--private flag"
    else:
        trigger = "CLAUSTRUM_PRIVATE=1"
    sys.stderr.write(
        "┌" + "─" * 63 + "┐\n"
        + "│ \U0001f512 PRIVATE SESSION" + " " * 44 + "│\n"
        + "│ This session is NOT being published to claustrum.finder.com.  │\n"
        + "│ Trigger: " + trigger.ljust(53) + "│\n"
        + "└" + "─" * 63 + "┘\n"
    )
    sys.stderr.flush()


def _resolve_auth():
    """Return (header_name, header_value) or None if no auth configured."""
    header = os.environ.get("CLAUSTRUM_AUTH_HEADER", "").strip() or "Authorization"
    cmd = os.environ.get("CLAUSTRUM_AUTH_COMMAND", "").strip()
    if cmd:
        try:
            result = subprocess.run(
                cmd, shell=True, capture_output=True, text=True, timeout=10,
            )
            value = result.stdout.strip()
            if value:
                return header, value
        except Exception:
            return None
        return None
    value = os.environ.get("CLAUSTRUM_AUTH_VALUE", "").strip()
    if value:
        return header, value
    return None


def _should_cloud_send(force_private=False):
    """Return True iff a cloud HTTP call should be attempted."""
    if not _cloud_url():
        return False
    if _privacy_mode(force_private):
        _print_private_banner_once()
        return False
    return True


_SSL_CTX = None
_SSL_CTX_RESOLVED = False


def _ssl_context():
    """Build (once, memoised) an SSL context that can actually verify certs.

    python.org macOS builds ship a default CA path that doesn't exist until
    `Install Certificates.command` is run, so urllib raises
    CERTIFICATE_VERIFY_FAILED and every cloud call silently fails. We never
    disable verification (these requests carry a bearer token) — instead we
    locate a real CA bundle: an explicit env override, then the interpreter
    default if present, then certifi, then well-known system bundles (Linux
    VMs + Homebrew included). Returns None to mean 'use urllib's default'."""
    global _SSL_CTX, _SSL_CTX_RESOLVED
    if _SSL_CTX_RESOLVED:
        return _SSL_CTX
    _SSL_CTX_RESOLVED = True
    import ssl

    env_ca = os.environ.get("CLAUSTRUM_CA_FILE") or os.environ.get("SSL_CERT_FILE")
    if env_ca and os.path.exists(env_ca):
        _SSL_CTX = ssl.create_default_context(cafile=env_ca)
        return _SSL_CTX

    paths = ssl.get_default_verify_paths()
    if (paths.cafile and os.path.exists(paths.cafile)) or (
        paths.capath and os.path.isdir(paths.capath)
    ):
        _SSL_CTX = ssl.create_default_context()
        return _SSL_CTX

    try:
        import certifi
        _SSL_CTX = ssl.create_default_context(cafile=certifi.where())
        return _SSL_CTX
    except Exception:
        pass

    for cand in (
        "/etc/ssl/cert.pem",                       # macOS, some BSDs
        "/etc/ssl/certs/ca-certificates.crt",      # Debian/Ubuntu
        "/etc/pki/tls/certs/ca-bundle.crt",        # RHEL/Fedora
        "/opt/homebrew/etc/openssl@3/cert.pem",    # Homebrew (Apple silicon)
        "/usr/local/etc/openssl@3/cert.pem",       # Homebrew (Intel)
    ):
        if os.path.exists(cand):
            _SSL_CTX = ssl.create_default_context(cafile=cand)
            return _SSL_CTX

    # Nothing found — fall back to urllib's default (verification stays on; if
    # it fails, it fails loudly-but-swallowed, same as before, never insecure).
    _SSL_CTX = None
    return _SSL_CTX


def _cloud_request(method, path, body=None, params=None, timeout=None):
    """Synchronous best-effort HTTP request. Returns dict on success, None
    on any failure. Caller has already gated on _should_cloud_send."""
    url = _cloud_url()
    if not url:
        return None
    full = url.rstrip("/") + path
    if params:
        clean = {k: v for k, v in params.items() if v is not None}
        if clean:
            full += "?" + _urlparse.urlencode(clean)
    data = None
    headers = {"Accept": "application/json"}
    if body is not None:
        data = json.dumps(body).encode("utf-8")
        headers["Content-Type"] = "application/json"
    auth = _resolve_auth()
    if auth:
        headers[auth[0]] = auth[1]
    req = _urlrequest.Request(full, data=data, headers=headers, method=method)
    try:
        with _urlrequest.urlopen(
            req, timeout=timeout or CLOUD_TIMEOUT, context=_ssl_context()
        ) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            return json.loads(raw) if raw else {}
    except Exception:
        return None


def _git_info(cwd):
    """Best-effort: derive (repo_name, branch) from a directory via git."""
    repo = None
    branch = None
    target = cwd or os.getcwd()
    try:
        result = subprocess.run(
            ["git", "-C", target, "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=1,
        )
        if result.returncode == 0:
            repo = os.path.basename(result.stdout.strip()) or None
    except Exception:
        pass
    try:
        result = subprocess.run(
            ["git", "-C", target, "branch", "--show-current"],
            capture_output=True, text=True, timeout=1,
        )
        if result.returncode == 0:
            branch = result.stdout.strip() or None
    except Exception:
        pass
    return repo, branch


def _cloud_checkin(uid, task=None, cwd=None, label=None, force_private=False,
                   timeout=None):
    """Best-effort write-through to POST /v1/checkin. Returns the parsed
    response dict (so callers can read topic_required / taxonomy /
    first_turn_message) or None on any failure / privacy suppression.

    PRIVACY (v2): `task` should be a COARSE label only — never the raw user
    prompt. The turn-1 leak in v1 came from publishing the first 200 chars of
    the prompt here. The detail layer (what's actually being worked on) goes
    through /v1/update with a value-scrubbed `working_on`, not through checkin.
    """
    if not _should_cloud_send(force_private):
        return None
    repo, branch = _git_info(cwd)
    body = {
        "uid": uid,
        "machine": socket.gethostname() or "unknown",
        "label": label or _get_session_label(),
        "task": task,
        "repo": repo,
        "branch": branch,
        "cwd": cwd,
        "is_quiet": _IS_HOOK_INVOCATION,
        "is_private": False,
    }
    return _cloud_request("POST", "/v1/checkin", body=body, timeout=timeout)


def _cloud_reset(force_private=False):
    """Best-effort POST /v1/reset. Returns dict on success, None on failure
    (including server 501)."""
    if not _should_cloud_send(force_private):
        return None
    return _cloud_request("POST", "/v1/reset", body={}, timeout=CLOUD_TIMEOUT_INTERACTIVE)


def _cloud_list_peers(uid, repo=None, topic=None, files_touched=None):
    """Best-effort GET /v1/list (v2 tiered-overlap dedup). Returns the full
    response dict or None.

    Shape (see cloud/server/app/routes/list_peers.py):
        {
          "tiers": {
            "t1_file_overlap": [peer, ...],          # same repo + ≥1 exact file
            "t2_path_or_pr":   [peer, ...],          # same repo + same PR / dir
            "t3_topic":        {topic, count, peers},
            "t4_repo":         {repo,  count, peers},
          },
          "solved": [solved_match, ...],             # done sessions, same tiers
        }
    Any dimension the client omits the server fills from the session's stored
    state (repo / topic / files / pr_number), so passing just `uid` works once
    the detail layer has been fed via /v1/update.
    """
    if not _should_cloud_send():
        return None
    params = {"uid": uid, "repo": repo, "topic": topic}
    if files_touched:
        params["files_touched"] = ",".join(files_touched)
    resp = _cloud_request("GET", "/v1/list", params=params)
    if isinstance(resp, dict) and isinstance(resp.get("tiers"), dict):
        return resp
    return None


def _cloud_archive(repo=None, topic=None, person=None, limit=20, offset=0):
    """Best-effort GET /v1/archive — paginated browse of the solved-problem
    archive (all done, resolution-bearing sessions, ANY age, hot + cold).
    Returns the response dict {items, limit, offset, has_more} or None.
    Unlike the per-turn nudge this is on-demand and unbounded by recency."""
    if not _should_cloud_send():
        return None
    params = {
        "repo": repo, "topic": topic, "person": person,
        "limit": limit, "offset": offset,
    }
    resp = _cloud_request("GET", "/v1/archive", params=params)
    if isinstance(resp, dict) and isinstance(resp.get("items"), list):
        return resp
    return None


def _cloud_update(uid, task=None, working_on=None, files_touched=None,
                  pr_number=None, last_push_at=None, status=None,
                  resolution=None, force_private=False, timeout=None):
    """Best-effort POST /v1/update — the detail layer. Only non-None fields are
    sent; the server COALESCE-merges them and *unions* files_touched into the
    existing set (so incremental single-file pushes never clobber earlier
    ones). Returns the parsed dict or None.

    `working_on` must be value-scrubbed (describes the work, never a raw secret
    / token / PII) — the privacy contract for the cloud-resident detail layer.
    """
    if not _should_cloud_send(force_private):
        return None
    body = {"uid": uid}
    if task is not None:
        body["task"] = task
    if working_on is not None:
        body["working_on"] = working_on
    if files_touched:
        body["files_touched"] = files_touched
    if pr_number is not None:
        body["pr_number"] = pr_number
    if last_push_at is not None:
        body["last_push_at"] = last_push_at
    if status is not None:
        body["status"] = status
    if resolution is not None:
        body["resolution"] = resolution
    return _cloud_request("POST", "/v1/update", body=body, timeout=timeout)


def _cloud_classify_self(uid, topic, confidence=80, domain=None,
                         force_private=False, timeout=None):
    """Best-effort POST /v1/classify_self — set the session's topic (+ domain) and
    get back historical_dedupe (active_peers + related_prs). Returns dict or None.

    `domain` is recorded on the session; when omitted the server derives it from
    the topic's domain in the taxonomy. `timeout` defaults to the interactive
    budget (foreground classify-self); the auto-classify hook path passes the
    tight CLOUD_TIMEOUT so a slow cloud never stalls the user's prompt."""
    if not _should_cloud_send(force_private):
        return None
    body = {"uid": uid, "topic": topic, "confidence": confidence}
    if domain:
        body["domain"] = domain
    return _cloud_request(
        "POST", "/v1/classify_self",
        body=body,
        timeout=timeout or CLOUD_TIMEOUT_INTERACTIVE,
    )


