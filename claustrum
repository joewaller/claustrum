def _cloud_topics():
    """Fetch the canonical taxonomy (GET /v1/topics). Interactive timeout — a
    classifying sub-agent / user is waiting on it. Returns the list of topic
    dicts ({name, description, parent, source, domain}), [] if the taxonomy is
    empty, or None if the cloud is unavailable / disabled / private."""
    if not _should_cloud_send():
        return None
    resp = _cloud_request("GET", "/v1/topics", timeout=CLOUD_TIMEOUT_INTERACTIVE)
    if isinstance(resp, dict):
        return resp.get("topics") or []
