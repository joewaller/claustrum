def cmd_checkin(args):
    """Register or update a session."""
    db = get_db()
    now = time.time()
    db.execute(
        """
        INSERT INTO sessions (uid, task, working_on, status, cwd, last_seen, started_at)
        VALUES (?, ?, ?, 'active', ?, ?, ?)
        ON CONFLICT(uid) DO UPDATE SET
            task = COALESCE(?, task),
            working_on = COALESCE(?, working_on),
            status = 'active',
            cwd = COALESCE(?, cwd),
            last_seen = ?
        """,
        (
            args.uid, args.task, args.files, args.cwd, now, now,
            args.task, args.files, args.cwd, now,
        ),
    )
    db.commit()
    db.close()
    print(f"Session {args.uid[:12]} checked in.")

    # Best-effort cloud write-through (silent on failure)
    _cloud_checkin(
        args.uid,
        task=args.task,
        cwd=args.cwd,
        force_private=getattr(args, "private", False),
        timeout=CLOUD_TIMEOUT_INTERACTIVE,
    )


def cmd_update(args):
    """Update session task or status."""
    db = get_db()
    now = time.time()

    updates = ["last_seen = ?"]
    params = [now]
    if args.task:
        updates.append("task = ?")
        params.append(args.task)
    if args.status:
        updates.append("status = ?")
        params.append(args.status)
    if args.files:
        updates.append("working_on = ?")
        params.append(args.files)

    params.append(args.uid)
    db.execute(
        f"UPDATE sessions SET {', '.join(updates)} WHERE uid = ?", params
    )
    db.commit()
    db.close()
    print(f"Session {args.uid[:12]} updated.")

    # Cloud detail layer. --files maps to the value-scrubbed `working_on` line.
    # Status is normalised to the server's enum (active|paused|done); anything
    # else is left for the local DB only.
    cloud_status = args.status if args.status in ("active", "paused", "done") else None
    _cloud_update(
        args.uid,
        task=args.task,
        working_on=args.files,
        status=cloud_status,
        force_private=getattr(args, "private", False),
        timeout=CLOUD_TIMEOUT_INTERACTIVE,
    )


def cmd_classify_self(args):
    """Tag this session with a topic (emergent taxonomy) and surface who has
    worked on it before — the cross-machine 'someone's already on this' signal."""
    resp = _cloud_classify_self(args.uid, args.topic, confidence=args.confidence)
    if resp is None:
        print(
            "Cloud classify failed or suppressed (no CLAUSTRUM_CLOUD_URL, "
            "private mode, offline, or server error). Nothing stored.",
            file=sys.stderr,
        )
        sys.exit(1)

    print(f"Session {args.uid[:12]} classified as topic '{args.topic}'.")
    dedupe = resp.get("historical_dedupe") or {}
    peers = dedupe.get("active_peers") or []
    prs = dedupe.get("related_prs") or []
    if peers:
        print(f"\n{len(peers)} other session(s) on this topic:")
        for p in peers:
            who = _short_email(p.get("user_email"))
            where = p.get("repo") or "?"
            on = p.get("working_on") or "-"
            print(f"  • {who} ({p.get('machine','?')}) in {where}: {on}")
    if prs:
        print("\nRelated PRs on this topic:")
        for pr in prs:
            print(f"  • {pr.get('repo')}#{pr.get('pr_number')} ({_short_email(pr.get('user_email'))})")
    if not peers and not prs:
        print("No prior sessions on this topic — you're first.")


def cmd_propose_topic(args):
    """Propose a new topic for the emergent taxonomy. Promotes to the official
    vocabulary once enough distinct users have proposed the same name."""
    resp = _cloud_propose_topic(args.uid, args.name, args.description)
    if resp is None:
        print(
            "Cloud propose failed or suppressed (no CLAUSTRUM_CLOUD_URL, "
            "private mode, offline, or server error). Nothing stored.",
            file=sys.stderr,
        )
        sys.exit(1)

    if resp.get("already_official"):
        print(f"Topic '{args.name}' is already official — just classify-self into it.")
        return
    count = resp.get("distinct_user_count", 0)
    threshold = resp.get("promotion_threshold", 2)
    print(f"Proposed topic '{args.name}'.")
    if resp.get("promotable"):
        print(f"  {count}/{threshold} distinct users — will promote on the next validate-proposals run.")
    else:
        print(f"  {count}/{threshold} distinct users so far — needs {threshold - count} more to promote.")


