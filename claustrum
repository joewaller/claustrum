    including server-emitted topic-alerts). Returns the messages list or None."""
    if not _should_cloud_send():
        return None
    resp = _cloud_request("GET", "/v1/inbox_drain", params={"uid": uid})
    if isinstance(resp, dict) and isinstance(resp.get("messages"), list):
