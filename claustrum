def cmd_propose_domain(args):
    """Add a domain to the canonical taxonomy immediately, unless it's a near-
    duplicate of an existing one (then it maps to that — use the existing name)."""
    resp = _cloud_propose_domain(args.uid, args.name, args.description)
    if resp is None:
