# Postgres connection string. Required.
CLAUSTRUM_DB_URL=postgresql://postgres:dev@localhost:5432/claustrum

# Optional: override the auth-header name for proxies that emit a different one.
# Default: X-Claustrum-User-Email
# Examples:
#   GCP IAP:           X-Goog-Authenticated-User-Email
#   Cloudflare Access: Cf-Access-Authenticated-User-Email
#   Tailscale serve:   Tailscale-User-Login
# CLAUSTRUM_AUTH_HEADER=X-Claustrum-User-Email

# Optional: set to 1 ONLY in dev to bypass proxy expectation. Production must
# never set this.
# CLAUSTRUM_DEV_TRUST_HEADER=0

# Optional: build version string returned by /healthz.
# CLAUSTRUM_VERSION=dev
