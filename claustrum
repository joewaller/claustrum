# ---------------------------------------------------------------------------
# Cross-machine inbox persistence (~/.claustrum/inbox/<uid>.json) + resume note
# ---------------------------------------------------------------------------

def _inbox_path(uid):
    return Path.home() / ".claustrum" / "inbox" / f"{uid}.json"


def _persist_inbox(uid, messages):
    """Append drained messages to ~/.claustrum/inbox/<uid>.json, de-duped by id.
    Best-effort — a write failure never propagates (callers are hooks)."""
    if not messages:
        return
    try:
        path = _inbox_path(uid)
        path.parent.mkdir(parents=True, exist_ok=True)
        existing = []
        if path.exists():
            try:
                existing = json.loads(path.read_text()) or []
            except Exception:
                existing = []
        seen = {m.get("id") for m in existing if isinstance(m, dict)}
        for m in messages:
            if m.get("id") not in seen:
                existing.append(m)
        path.write_text(json.dumps(existing, indent=2, default=str))
    except Exception:
        pass


def _format_resume(resume):
    """One-line human summary of a /v1/resume_check payload, or '' if nothing
    notable changed since the session was last seen."""
    if not isinstance(resume, dict):
        return ""
    since = resume.get("since_last_seen") or {}
    bits = []
    peers = since.get("peer_activity") or []
    if peers:
        bits.append(f"{len(peers)} peer(s) active in your repo/topic")
    prs = since.get("merged_prs") or []
    if prs:
        bits.append(f"{len(prs)} PR(s) finished")
    expired = since.get("expired_claims") or 0
    if expired:
        bits.append(f"{expired} of your file claim(s) expired")
    if not bits:
        return ""
    paused = resume.get("paused_for_seconds")
    prefix = ""
    if isinstance(paused, (int, float)) and paused > 300:
        prefix = f"Resumed after {_format_ago(paused)}. "
    return prefix + "Since last seen: " + "; ".join(bits) + "."


# ---------------------------------------------------------------------------
# Detail-layer derivation — repo-relative paths + git/gh metadata
#
# The cloud dedup engine intersects files_touched as a SET across machines, so
# paths MUST be repo-relative (two people on the same file have identical rel
# paths but different absolute ones). pr_number/last_push_at let the server
# bucket peers into the t2 "same PR" tier.
# ---------------------------------------------------------------------------

def _rel_to_repo(filepath, cwd=None):
    """Return `filepath` relative to its git toplevel, for cross-machine set
    overlap. Falls back to the basename if the file isn't inside a repo."""
    if not filepath:
        return None
    target = os.path.dirname(filepath) or (cwd or os.getcwd())
    try:
        result = subprocess.run(
            ["git", "-C", target, "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=1,
        )
        if result.returncode == 0:
            top = result.stdout.strip()
            if top:
                try:
                    return os.path.relpath(os.path.abspath(filepath), top)
                except ValueError:
                    pass
    except Exception:
        pass
    return os.path.basename(filepath)


def _git_last_push_at(target):
    """Best-effort ISO timestamp approximating the last push: commit date of the
    upstream-tracked HEAD (@{push}), falling back to HEAD's commit date. Local
    and fast — no network."""
    target = target or os.getcwd()
    for ref in ("@{push}", "HEAD"):
        try:
            result = subprocess.run(
                ["git", "-C", target, "log", "-1", "--format=%cI", ref],
                capture_output=True, text=True, timeout=1,
            )
            if result.returncode == 0 and result.stdout.strip():
                return result.stdout.strip()
        except Exception:
            pass
    return None


_PR_CACHE_PATH = DB_DIR / "pr-cache.json"
_PR_CACHE_TTL = 300  # seconds — re-query gh at most once per 5 min per branch


def _get_pr_number(target, repo, branch):
    """Best-effort current-branch PR number via `gh`, cached per (repo, branch)
    with a TTL so it isn't re-queried on every edit. Caches negative results
    too (a branch with no PR shouldn't trigger a gh call every keystroke).
    Returns int or None."""
    if not repo or not branch:
        return None
    key = f"{repo}:{branch}"
    now = time.time()

    cache = {}
    try:
        if _PR_CACHE_PATH.exists():
            cache = json.loads(_PR_CACHE_PATH.read_text())
    except Exception:
        cache = {}

    entry = cache.get(key)
    if isinstance(entry, dict) and (now - entry.get("ts", 0)) < _PR_CACHE_TTL:
        return entry.get("pr")

    pr = None
    try:
        result = subprocess.run(
            ["gh", "pr", "view", "--json", "number", "-q", ".number"],
            cwd=target or os.getcwd(),
            capture_output=True, text=True, timeout=3,
        )
        if result.returncode == 0 and result.stdout.strip().isdigit():
            pr = int(result.stdout.strip())
    except Exception:
        pr = None

    cache[key] = {"pr": pr, "ts": now}
    try:
        DB_DIR.mkdir(parents=True, exist_ok=True)
        _PR_CACHE_PATH.write_text(json.dumps(cache))
    except Exception:
        pass
    return pr


# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

def get_db():
    """Get a database connection with WAL mode and schema initialized."""
    DB_DIR.mkdir(parents=True, exist_ok=True)
    db = sqlite3.connect(str(DB_PATH), timeout=5)
    db.row_factory = sqlite3.Row
    db.execute("PRAGMA journal_mode=WAL")
    db.execute("PRAGMA busy_timeout=5000")
    _init_schema(db)
    return db


def _init_schema(db):
    db.executescript("""
        CREATE TABLE IF NOT EXISTS sessions (
            uid          TEXT PRIMARY KEY,
            label        TEXT,
            task         TEXT,
            working_on   TEXT,
            status       TEXT DEFAULT 'active',
            cwd          TEXT,
            last_seen    REAL NOT NULL,
            started_at   REAL NOT NULL,
            -- Liveness fields (process/tmux ground truth, not just the timer).
            -- host: only same-host sessions are tmux/boot-reaped; others fall
            --       back to the last_seen timer (cloud owns cross-machine).
            -- tmux_pane: e.g. '%28' — matched against `tmux list-panes -a`.
            -- pid: claude process pid — os.kill(pid,0) fallback when no pane.
            -- boot_id: machine boot epoch — a session from a previous boot is
            --          unambiguously dead (kills PID-reuse-after-reboot).
            host         TEXT,
            tmux_pane    TEXT,
            pid          INTEGER,
            boot_id      TEXT
        );

        CREATE TABLE IF NOT EXISTS messages (
            id           INTEGER PRIMARY KEY AUTOINCREMENT,
            from_uid     TEXT,
            to_uid       TEXT,
            type         TEXT NOT NULL DEFAULT 'info',
            body         TEXT NOT NULL,
            created_at   REAL NOT NULL,
            read_at      REAL
        );

        CREATE TABLE IF NOT EXISTS claims (
            filepath     TEXT NOT NULL,
            uid          TEXT NOT NULL,
            claimed_at   REAL NOT NULL,
            PRIMARY KEY (filepath, uid)
        );

        CREATE INDEX IF NOT EXISTS idx_messages_to
            ON messages(to_uid, read_at);
        CREATE INDEX IF NOT EXISTS idx_claims_file
            ON claims(filepath);
        CREATE INDEX IF NOT EXISTS idx_sessions_status
            ON sessions(status);
    """)
    # Migrate older DBs: add liveness columns if missing. Existing rows get
    # NULLs and fall back to the timer until their next heartbeat repopulates
    # them, so the upgrade is non-breaking.
    #
    # topic / topic_confidence mirror the cloud's emergent taxonomy down to the
    # local DB so a session's subject is joinable OFFLINE by uid (the cloud had
    # these from day one; locally they were missing). Populated two ways:
    #   - at classify time (cmd_classify_self writes here, authoritative), and
    #   - mirrored down from the cloud checkin response when already tagged.
    # Confidence is 0-100; heuristic auto-picks score low, deliberate picks 80.
    #
    # classify_prompted: set once we've injected the tier-2 sub-agent classify
    # delegation for an untagged session. Guards against re-injecting it every
    # turn — an untagged session costs ONE line ever, then goes quiet (vs the old
    # behaviour of re-dumping the whole taxonomy into main context each turn).
    existing = {r["name"] for r in db.execute("PRAGMA table_info(sessions)")}
    for col, decl in (
        ("host", "TEXT"),
        ("tmux_pane", "TEXT"),
        ("pid", "INTEGER"),
        ("boot_id", "TEXT"),
        ("topic", "TEXT"),
        ("topic_confidence", "INTEGER"),
        ("domain", "TEXT"),
        ("classify_prompted", "INTEGER DEFAULT 0"),
    ):
        if col not in existing:
            db.execute(f"ALTER TABLE sessions ADD COLUMN {col} {decl}")
    db.commit()


# ---------------------------------------------------------------------------
# Liveness — derive "is this session actually alive right now?" from the OS /
# tmux, not from a heartbeat timer. A timer can't tell an idle session (user
# asleep) from a dead one (reboot / crash / kill -9 — no SessionEnd fires), so
# ghosts linger as 'active' for days AND their file claims keep blocking live
# sessions via the PreToolUse hook. tmux pane existence + a boot-epoch guard is
# ground truth and costs one ~5ms subprocess call.
# ---------------------------------------------------------------------------

_HOST = None
_BOOT_ID = None


def _host():
    global _HOST
    if _HOST is None:
        _HOST = socket.gethostname() or "unknown"
    return _HOST


def _boot_id():
    """A stable id for the current OS boot. Sessions whose stored boot_id
    differs are from a previous boot and are unambiguously dead. Best-effort:
    returns None if it can't be determined (then the boot guard is skipped)."""
    global _BOOT_ID
    if _BOOT_ID is not None:
        return _BOOT_ID or None  # cached "" sentinel means "unknown"
    val = ""
    try:
        if sys.platform == "darwin":
            out = subprocess.run(
                ["sysctl", "-n", "kern.boottime"],
                capture_output=True, text=True, timeout=2,
            ).stdout
            # "{ sec = 1781924595, usec = 54718 } Sat Jun 20 ..."
            import re
            m = re.search(r"sec\s*=\s*(\d+)", out)
            if m:
                val = m.group(1)
        else:  # linux: btime in /proc/stat
            with open("/proc/stat") as f:
                for line in f:
                    if line.startswith("btime "):
                        val = line.split()[1]
                        break
    except Exception:
        val = ""
    _BOOT_ID = val
    return val or None


def _live_tmux_panes():
    """Set of live tmux pane ids (e.g. {'%2','%28'}) across ALL sessions on
    this host. Returns None if tmux is unavailable / not running — callers must
    treat None as 'can't tell' and fall back to the timer rather than reaping
    everything."""
    pane = os.environ.get("TMUX_PANE")
    if not pane and not os.environ.get("TMUX"):
        return None
    try:
        result = subprocess.run(
            ["tmux", "list-panes", "-a", "-F", "#{pane_id}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0:
            return None
        panes = {p.strip() for p in result.stdout.splitlines() if p.strip()}
        return panes or None
    except Exception:
        return None


def _live_tmux_sessions():
    """Set of live tmux session NAMES on this host. Used as the reap fallback
    for rows with no recorded pane (e.g. legacy rows migrated in before the
    liveness columns existed) — claustrum's label IS the tmux session name.
    Returns None when tmux is unavailable (caller falls back to the timer)."""
    if not os.environ.get("TMUX"):
        return None
    try:
        result = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0:
            return None
        names = {n.strip() for n in result.stdout.splitlines() if n.strip()}
        return names or None
    except Exception:
        return None


def _pane_session_names():
    """Map of live tmux pane id -> its owning session NAME, across all sessions
    on this host. Claustrum's label IS the tmux session name, but a session
    renames itself (convention: `tmux rename-session <slug>`) AFTER it checks in,
    and the stored label is otherwise only re-derived on the next prompt. The
    heartbeat uses this to propagate a rename without waiting for a prompt.
    Returns None if tmux is unavailable."""
    if not os.environ.get("TMUX"):
        return None
    try:
        result = subprocess.run(
            ["tmux", "list-panes", "-a", "-F", "#{pane_id}\t#{session_name}"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0:
            return None
        out = {}
        for line in result.stdout.splitlines():
            pane, _, name = line.partition("\t")
            pane, name = pane.strip(), name.strip()
            if pane and name:
                out[pane] = name
        return out or None
    except Exception:
        return None


# Interactive coding-agent CLIs whose tmux panes Claustrum tracks. Matched by
# path component / word so 'agy' can't hit 'legacy' etc. Extend as agents land.
_AGENT_NAMES = {"claude", "agy", "antigravity", "gemini", "gemma", "codex"}


def _is_agent_cmd(command):
    """True if a process command line is one of the tracked agent CLIs. Matches
    on a path component or whitespace-delimited token (so '.../bin/agy' and
    'node .../claude/cli.js' match, but 'legacy' does not)."""
    import re
    return any(t in _AGENT_NAMES for t in re.split(r"[\s/\\]+", command.lower()) if t)


def _live_agent_panes():
    """{pane_id: agent_pid} for tmux panes whose process subtree is running a
    tracked coding agent (claude / agy / …). Lets the heartbeat ADOPT a live
    agent session that has no claustrum row yet (its row was lost and it hasn't
    prompted since) so it shows without interaction — keyed on the agent pid so
    it reaps cleanly when the agent exits. One `tmux` + one `ps` snapshot, so it
    stays cheap on the per-tick path. None if tmux is down."""
    if not os.environ.get("TMUX"):
        return None
    try:
        r = subprocess.run(
            ["tmux", "list-panes", "-a", "-F", "#{pane_id}\t#{pane_pid}"],
            capture_output=True, text=True, timeout=2,
        )
        if r.returncode != 0:
            return None
        pane_pid = {}
        for line in r.stdout.splitlines():
            p, _, pid = line.partition("\t")
            if p.strip() and pid.strip():
                pane_pid[p.strip()] = pid.strip()
        ps = subprocess.run(
            ["ps", "-axo", "pid=,ppid=,command="],
            capture_output=True, text=True, timeout=3,
        )
        children, cmd = {}, {}
        for line in ps.stdout.splitlines():
            parts = line.split(None, 2)
            if len(parts) < 3:
                continue
            pid, ppid, c = parts
            children.setdefault(ppid, []).append(pid)
            cmd[pid] = c
        def agent_pid(root):
            # DFS the pane's subtree; return the first agent process pid found.
            seen, stack = set(), [root]
            while stack:
                pid = stack.pop()
                if pid in seen:
                    continue
                seen.add(pid)
                if _is_agent_cmd(cmd.get(pid, "")):
                    return pid
                stack.extend(children.get(pid, []))
            return None
        out = {}
        for pane, ppid in pane_pid.items():
            ap = agent_pid(ppid)
            if ap:
                out[pane] = ap
        return out or None
    except Exception:
        return None


def _pid_alive(pid, boot_id, cur_boot):
    """True if a recorded Claude pid is still running. Boot-guarded: a pid from a
    previous boot counts as dead (PID reuse across reboots). A missing or
    malformed pid is unverifiable, so returns True — we never reap on a guess.
    PermissionError means the pid exists under another user, i.e. alive."""
    if not pid:
        return True
    if cur_boot and boot_id and boot_id != cur_boot:
        return False
    try:
        os.kill(int(pid), 0)
        return True
    except ProcessLookupError:
        return False
    except (ValueError, TypeError):
        return True
    except PermissionError:
        return True


def _reap_dead(db, now):
    """Mark genuinely-dead local sessions 'dead' and release their stale file
    claims, using tmux/boot ground truth instead of the heartbeat timer.
    Cross-host sessions and any we can't verify are left to _clean_stale's
    timer. A false reap is self-healing — the session re-registers 'active' on
    its next heartbeat. Returns the list of reaped uids (callers that only need
    a count can take len())."""
    boot = _boot_id()
    host = _host()
    live_panes = _live_tmux_panes()
    live_sessions = _live_tmux_sessions()

    rows = db.execute(
        "SELECT uid, label, host, tmux_pane, pid, boot_id FROM sessions "
        "WHERE status IN ('active', 'stale')"
    ).fetchall()

    dead = []
    for s in rows:
        # Only adjudicate local sessions. A NULL host is a legacy/unknown row;
        # since the DB is single-machine, treat it as a local candidate so the
        # fallbacks below can still reap pre-upgrade ghosts.
        if s["host"] and s["host"] != host:
            continue

        # 1) Previous boot → definitively dead (handles reboot + PID reuse).
        if boot and s["boot_id"] and s["boot_id"] != boot:
            dead.append(s["uid"])
            continue

        # 2) Recorded a tmux pane.
        if s["tmux_pane"] and live_panes is not None:
            if s["tmux_pane"] not in live_panes:
                dead.append(s["uid"])           # pane gone → dead
                continue
            # Pane alive — but a tmux pane outlives its Claude process: quit
            # Claude and the shell/pane lingers. If we recorded the Claude pid
            # and it's gone, the session is dead despite the surviving pane. This
            # also dedups a reused pane — a stale registration's old pid is dead
            # while the current session's pid is alive on the same pane.
            if not _pid_alive(s["pid"], s["boot_id"], boot):
                dead.append(s["uid"])
            continue

        # 3) No pane recorded but tmux is up → match label against live tmux
        #    session names (covers legacy rows). Conservative: duplicate labels
        #    keep all matches alive, and a wrong reap self-heals.
        if not s["tmux_pane"] and live_sessions is not None and s["label"]:
            if _clean_label(s["label"]) not in live_sessions:
                dead.append(s["uid"])
            continue

        # 4) Non-tmux, but a pid is recorded → os.kill(pid,0) probe, boot-guarded
        #    so a reused PID can't resurrect a ghost.
        if not s["tmux_pane"] and s["pid"] and (not boot or s["boot_id"] == boot):
            try:
                os.kill(int(s["pid"]), 0)
            except (ProcessLookupError, ValueError):
                dead.append(s["uid"])
            except PermissionError:
                pass  # alive, owned by another user — treat as live
            continue

        # 5) Can't verify (no pane, no pid, tmux down) → leave to the timer.

    for uid in dead:
        db.execute("UPDATE sessions SET status = 'dead' WHERE uid = ?", (uid,))
        db.execute("DELETE FROM claims WHERE uid = ?", (uid,))

    return dead


def _clean_stale(db, now):
    """Mark stale sessions and release their claims. Returns count."""
    threshold = now - STALE_SECONDS
    stale = db.execute(
        "SELECT uid FROM sessions WHERE last_seen < ? AND status = 'active'",
        (threshold,)
    ).fetchall()

    for s in stale:
        db.execute(
            "UPDATE sessions SET status = 'stale' WHERE uid = ?",
            (s["uid"],)
        )
        db.execute("DELETE FROM claims WHERE uid = ?", (s["uid"],))

    # Purge old done/stale sessions and read messages. 'dead' sessions are
    # verified-gone (reaped by _reap_dead), so drop them right away rather than
    # waiting out CLEANUP_SECONDS — their uid never returns.
    old = now - CLEANUP_SECONDS
    db.execute("DELETE FROM sessions WHERE status = 'dead'")
    db.execute(
        "DELETE FROM sessions WHERE last_seen < ? AND status IN ('stale','done')",
        (old,),
    )
    db.execute(
        "DELETE FROM messages WHERE read_at IS NOT NULL AND read_at < ?",
        (old,),
    )

    return len(stale)


def _get_session_label():
    """Get a human-readable label for this terminal session.

    Fallback chain (first non-empty wins):
      1. CLAUSTRUM_LABEL env var (explicit override)
      2. tmux pane title (if inside tmux)
      3. iTerm2 tab name (macOS)
      4. Terminal.app window name (macOS)
      5. basename of working directory
    """
    # 1. Explicit override
    label = os.environ.get("CLAUSTRUM_LABEL", "").strip()
    if label:
        return label

    # 2. tmux session name (the slug set via tmux rename-session)
    try:
        pane = os.environ.get("TMUX_PANE")
        if pane:
            result = subprocess.run(
                ["tmux", "display-message", "-t", pane, "-p", "#{session_name}"],
                capture_output=True, text=True, timeout=2,
            )
            name = result.stdout.strip()
            if name:
                return name
    except Exception:
        pass

    # 3. iTerm2 tab name (only if iTerm2 is already running)
    # 4. Terminal.app window name (only if Terminal is already running)
    # `tell application "X"` launches X if not running, so guard with
    # System Events process check (does not launch the app).
    for app, query in (
        ("iTerm2", 'tell application "iTerm2" to get name of current tab of current window'),
        ("Terminal", 'tell application "Terminal" to get name of front window'),
    ):
        try:
            check = subprocess.run(
                ["osascript", "-e",
                 f'tell application "System Events" to (name of processes) contains "{app}"'],
                capture_output=True, text=True, timeout=2,
            )
            if check.stdout.strip().lower() != "true":
                continue
            result = subprocess.run(
                ["osascript", "-e", query],
                capture_output=True, text=True, timeout=2,
            )
            name = result.stdout.strip()
            if name and result.returncode == 0:
                return name
        except Exception:
            pass

    # 5. Directory basename as last resort
    return os.path.basename(os.getcwd())


def _clean_label(label):
    """Strip leading status indicators (braille, emoji, symbols) from labels.

    Pane titles may already contain status indicators from other tools
    (e.g. statusline). Strip them so Claustrum can prepend its own.
    """
    import re
    # Strip leading braille patterns (U+2800-U+28FF), common symbols, and whitespace
    return re.sub(r'^[\u2800-\u28FF✳◇◆●○■□▪▫★☆⚡🤖\s]+', '', label).strip()


def _ensure_session(db, uid, cwd=None):
    """Register or refresh a session, recording liveness fields (host, tmux
    pane, pid, boot id) so _reap_dead can verify it against the live OS/tmux
    state rather than guessing from a timer."""
    now = time.time()
    label = _get_session_label()
    host = _host()
    pane = os.environ.get("TMUX_PANE") or None
    # The hook runs as a child of the Claude process; its parent pid is the best
    # available process handle for liveness when there's no tmux pane.
    try:
        pid = os.getppid()
    except Exception:
        pid = None
    boot = _boot_id()
    db.execute(
        """
        INSERT INTO sessions
            (uid, label, status, cwd, last_seen, started_at,
             host, tmux_pane, pid, boot_id)
        VALUES (?, ?, 'active', ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(uid) DO UPDATE SET
            label = COALESCE(?, label),
            status = 'active',
            cwd = COALESCE(?, cwd),
            last_seen = ?,
            host = COALESCE(?, host),
            tmux_pane = COALESCE(?, tmux_pane),
            pid = COALESCE(?, pid),
            boot_id = COALESCE(?, boot_id)
        """,
        (uid, label, cwd, now, now, host, pane, pid, boot,
         label, cwd, now, host, pane, pid, boot),
    )


def _set_local_topic(db, uid, topic, confidence=None, domain=None):
    """Mirror a session's topic (+ domain) into the local DB so it's joinable
    offline by uid (the downstream nugget-miner joins transcripts → topics on the
    session uuid). Only writes when there's an actual topic; never clobbers an
    existing topic with NULL. Domain is written when provided (never nulled).
    Caller commits."""
    if not topic:
        return
    db.execute(
        "UPDATE sessions SET topic = ?, topic_confidence = ? WHERE uid = ?",
        (topic, confidence, uid),
    )
    if domain:
        db.execute(
            "UPDATE sessions SET domain = ? WHERE uid = ?", (domain, uid)
        )


# Tiny stopword set + tokenizer for the cheap, LLM-free auto-classifier. Kept
# deliberately small — this is keyword overlap, not NLP.
_STOPWORDS = frozenset(
    "the a an and or of to in on for with by at from is are be this that it as "
    "into via add adds added fix fixes fixed update updates updated make makes "
    "work working session claude code task new use using run running get".split()
)


def _tokenize(text):
    """Lowercase alphanumeric tokens, kebab/snake split, stopwords + 2-char
    noise dropped. Returns a set (overlap scoring, order-independent)."""
    if not text:
        return set()
    import re
    toks = re.split(r"[^a-z0-9]+", str(text).lower())
    return {t for t in toks if len(t) > 2 and t not in _STOPWORDS}


def _auto_classify_topic(taxonomy, signal, floor=False):
    """Cheap, local, LLM-free best-guess topic for an untagged session.

    Scores keyword overlap between the session's signal (task / repo / cwd /
    prompt — all of which stay on this machine) and each taxonomy topic's
    name+description. A name-token hit weighs 3x a description-token hit.

    Default (floor=False, the prompt path): picks the leader only if it clears a
    floor AND beats the runner-up, so weak/tied matches return (None, None) and
    fall through to the deliberate sub-agent classify (better quality).

    floor=True (the tick path): ALWAYS commits a coverage guarantee — a weak/tied
    match still returns its best guess at low confidence, and a no-overlap session
    falls back to the generic 'app' topic. So every session the tick sees gets a
    domain+topic (domain is derived server-side from the topic); the named-turn
    sub-agent later supersedes it (higher confidence). See the confidence-gated
    re-prompt in hook_prompt.

    Returns (topic_name, confidence) or (None, None). Confidence is capped below a
    human/LLM pick (80) so a later classify-self always supersedes the heuristic.
    """
    if not taxonomy:
        return None, None
    sig = _tokenize(signal)
    scored = []
    for t in taxonomy:
        name = (t.get("name") or "").strip()
        if not name:
            continue
        name_toks = _tokenize(name)
        desc_toks = _tokenize(t.get("description") or "")
        score = 3 * len(sig & name_toks) + len(sig & desc_toks)
        if score > 0:
            scored.append((score, name))
    if scored:
        scored.sort(reverse=True)
        best_score, best_name = scored[0]
        runner = scored[1][0] if len(scored) > 1 else 0
        # A real signal (>=2) with a clear lead is a confident pick either way.
        if best_score >= 2 and best_score > runner:
            return best_name, min(60, 30 + 5 * best_score)
        # Weak/tied: prompt path leaves it for the sub-agent; tick floor commits
        # the best guess anyway (low confidence) to guarantee coverage.
        return (best_name, 25) if floor else (None, None)
    # No keyword overlap at all (e.g. a generic 'session01' with no signal).
    if floor:
        names = {(t.get("name") or "").strip() for t in taxonomy if (t.get("name") or "").strip()}
        default = "app" if "app" in names else (sorted(names)[0] if names else None)
        return (default, 20) if default else (None, None)
    return None, None


def _format_ago(seconds):
    s = int(seconds)
    if s < 60:
        return f"{s}s ago"
    if s < 3600:
        return f"{s // 60}m ago"
    return f"{s // 3600}h ago"


def _short_email(email):
    """`joe.waller@finder.com` -> `joe.waller` for compact peer lines."""
    if not email:
        return "someone"
    return email.split("@", 1)[0]


def _format_date(ts):
    """ISO timestamp string -> `YYYY-MM-DD` for compact display. Falls back to
    the raw value on anything unexpected."""
    if not ts:
        return "?"
    return str(ts)[:10]


def _render_cloud_tiers(tiers):
    """Render the /v1/list tiered-overlap result for the heartbeat tray. t1/t2
    are collisions (someone is on YOUR files / PR) and get surfaced loudly;
    t3/t4 are softer "also in this topic/repo" counts. Returns a list of lines
    (empty if nothing worth showing)."""
    if not isinstance(tiers, dict):
        return []

    t1 = tiers.get("t1_file_overlap") or []
    t2 = tiers.get("t2_path_or_pr") or []
    t3 = tiers.get("t3_topic") or {}
    t4 = tiers.get("t4_repo") or {}

    lines = []

    if t1:
        lines.append("  ⚠️  CROSS-MACHINE FILE COLLISION — someone is already editing your files:")
        for p in t1:
            who = _short_email(p.get("user_email"))
            files = ", ".join(p.get("overlap_files") or []) or "?"
            on = p.get("working_on") or p.get("topic") or "-"
            lines.append(f"      • {who} ({p.get('machine','?')}): {files}  — {on}")

    if t2:
        lines.append("  ⚠️  Same PR / directory as you:")
        for p in t2:
            who = _short_email(p.get("user_email"))
            reason = p.get("reason") or ""
            on = p.get("working_on") or p.get("topic") or "-"
            lines.append(f"      • {who} ({p.get('machine','?')}) [{reason}] — {on}")

    if isinstance(t3, dict) and t3.get("count"):
        topic = t3.get("topic") or "?"
        peers = ", ".join(
            _short_email(p.get("user_email")) for p in (t3.get("peers") or [])
        )
        extra = f" ({peers})" if peers else ""
        lines.append(f"  · {t3['count']} other session(s) on topic '{topic}'{extra}")

    if isinstance(t4, dict) and t4.get("count"):
        repo = t4.get("repo") or "?"
        lines.append(f"  · {t4['count']} other session(s) in repo '{repo}'")

    if lines:
        lines.insert(0, "Cross-machine (claustrum cloud):")
    return lines


# Tiers surfaced loudly (high-signal: same files / same PR-or-dir). Topic / repo
# matches (t3/t4) are weaker — a quiet footnote, not a banner — so the "already
# solved" warning doesn't cry wolf on every repo-mate.
_LOUD_SOLVED_TIERS = ("t1_file_overlap", "t2_path_or_pr")


def _format_solved_entry(s):
    """One human line for a solved-archive match. `s` is a server `solved`
    entry: {person, repo, topic, pr_number, done_at, resolution, match_tier,
    overlap_files?}."""
    who = _short_email(s.get("person"))
    when = _format_date(s.get("done_at"))
    res = str(s.get("resolution") or "").strip() or "(no resolution recorded)"
    pr = s.get("pr_number")
    pr_s = f" (PR #{pr})" if pr else ""
    overlap = s.get("overlap_files") or []
    where = ", ".join(overlap) if overlap else (s.get("repo") or s.get("topic") or "?")
    return f"{who}, {when} — {res}{pr_s}  [{where}]"


def _render_solved(solved):
    """Render the 'has this been solved before?' block for the turn-1 tray.
    Loud tiers (file / PR overlap) get a warning banner; weak tiers (topic /
    repo) are a one-line footnote. Returns a list of lines (empty if none)."""
    if not solved:
        return []
    # Only surface entries with a real resolution — a bare done row (no
    # resolution recorded) is board state, not useful "solved" knowledge, so
    # showing it is just noise.
    solved = [s for s in solved if str(s.get("resolution") or "").strip()]
    if not solved:
        return []

    # Dedup: the same completed work can match on several tiers / rows (e.g. one
    # PR surfacing three times), which is pure noise in the tray. Collapse by
    # (person, pr, resolution) — the identity of the solved work, not the match.
    def _dedup(entries):
        seen = set()
        out = []
        for s in entries:
            key = (
                s.get("person"),
                s.get("pr_number"),
                str(s.get("resolution") or "").strip(),
            )
            if key in seen:
                continue
            seen.add(key)
            out.append(s)
        return out

    loud = _dedup([s for s in solved if s.get("match_tier") in _LOUD_SOLVED_TIERS])
    weak = _dedup([s for s in solved if s.get("match_tier") not in _LOUD_SOLVED_TIERS])

    lines = []
    if loud:
        lines.append("  \U0001f5c2️  MAY ALREADY BE SOLVED — matching work was completed before:")
        for s in loud:
            lines.append(f"      • {_format_solved_entry(s)}")
    if weak:
        lines.append("  \U0001f5c2️  Related solved work (weaker match — same topic/repo):")
        for s in weak[:3]:
            lines.append(f"      • {_format_solved_entry(s)}")
    return lines


def _mirror_or_autoclassify(db, uid, checkin_resp, signal):
    """Keep the local topic mirror in sync from the cloud checkin response.

    Two cases, both writing the LOCAL DB only (no network here — the caller
    fires the cloud push after the DB is closed so it never holds a lock open
    across a request):
      - cloud already has a topic  -> mirror it straight down locally.
      - cloud wants a topic + sent a taxonomy -> cheap local heuristic pick;
        on a confident match, write it locally and return it so the caller can
        best-effort push it to the cloud too.

    Returns (auto_topic, auto_conf) when THIS turn auto-picked a topic (caller
    then pushes it to the cloud + can surface a note), else (None, None)."""
    if not isinstance(checkin_resp, dict):
        return None, None
    existing = checkin_resp.get("topic")
    if existing:
        _set_local_topic(db, uid, existing, checkin_resp.get("topic_confidence"),
                         domain=checkin_resp.get("domain"))
        return None, None
    if not checkin_resp.get("topic_required"):
        return None, None
    topic, conf = _auto_classify_topic(checkin_resp.get("taxonomy") or [], signal)
    if topic:
        _set_local_topic(db, uid, topic, conf)
        return topic, conf
    return None, None


def _build_classify_block(uid):
    """Directive to classify this session by DOMAIN + TOPIC via a throwaway
    sub-agent — the Phase 2 reliability path.

    Phrased as an imperative (like the rename nudge the agent already obeys),
    fired once the session has a meaningful name and re-asserted each turn until
    it carries a confident classification (the caller gates on label + confidence
    + a small nudge cap). The taxonomy lives only in the sub-agent's throwaway
    context, so the main session's going-forward cost stays ~zero. A new
    domain/topic the sub-agent proposes becomes canonical immediately (the cloud
    dedups near-duplicates), so 'sufficiently dissimilar' work is free to mint its
    own. Returns a list of lines."""
    return [
        "Claustrum: classify this session now (it has no confident domain+topic yet).",
        "  Spawn a sub-agent (so the taxonomy stays out of this context) and have it:",
        "    1. run  claustrum domains   and   claustrum topics",
        "    2. pick the best-fit domain + topic. If nothing is close, first run",
        f"         claustrum propose-domain {uid} \"<name>\" \"<desc>\"   (only if no domain fits)",
        f"         claustrum propose-topic {uid} \"<name>\" \"<desc>\" --domain \"<domain>\"",
        f"    3. run  claustrum classify-self {uid} \"<topic>\" --domain \"<domain>\"",
    ]


# ---------------------------------------------------------------------------
# Hook handlers  (read JSON from stdin, interact with DB, write to stdout)
#
# IMPORTANT: hooks must never crash. A broken hook blocks the user's prompt.
# Every handler is wrapped in try/except at the dispatch level.
# ---------------------------------------------------------------------------

def hook_prompt(_args):
    """UserPromptSubmit — heartbeat, read messages, inject context."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    cwd = data.get("cwd")
    prompt = (data.get("prompt") or "")[:200]  # first 200 chars

    db = get_db()
    now = time.time()

    _ensure_session(db, uid, cwd)
    # Reap dead same-host sessions (and release their stale claims) using
    # tmux/boot ground truth, so the roster below reflects who's actually alive.
    _reap_dead(db, now)

    # Auto-set task from user's prompt LOCALLY so same-machine sessions see
    # intent. This stays in SQLite and NEVER leaves the machine.
    if prompt:
        db.execute(
            "UPDATE sessions SET task = ? WHERE uid = ?",
            (prompt, uid),
        )

    # Best-effort cloud write-through. PRIVACY (v2): the raw prompt is NOT sent
    # — only the coarse `label` (tmux slug, derived inside _cloud_checkin) goes
    # up, killing the v1 turn-1 leak. The response tells us whether the session
    # still needs a topic so the agent can self-classify. Privacy gate honors
    # CLAUSTRUM_PRIVATE / CLAUSTRUM_PUBLIC internally.
    checkin_resp = _cloud_checkin(uid, task=None, cwd=cwd)

    # Topic mirror: pull the cloud's topic down locally (offline-joinable by
    # uid), or — if still untagged — make a cheap local heuristic pick now so
    # coverage is reliable instead of waiting on a manual classify-self. The
    # signal (prompt + repo/cwd dir + label) never leaves the machine; only the
    # chosen topic NAME (already public taxonomy) is pushed below. No network
    # while the DB is open.
    auto_signal = " ".join(
        filter(None, [prompt, os.path.basename(cwd or ""), _get_session_label()])
    )
    auto_topic, auto_conf = _mirror_or_autoclassify(
        db, uid, checkin_resp, auto_signal
    )

    # Unread messages for this session (or broadcasts), excluding own
    messages = db.execute(
        """
        SELECT from_uid, type, body, created_at FROM messages
        WHERE (to_uid = ? OR to_uid IS NULL)
          AND read_at IS NULL
          AND from_uid != ?
        ORDER BY created_at
        """,
        (uid, uid),
    ).fetchall()

    if messages:
        db.execute(
            """
            UPDATE messages SET read_at = ?
            WHERE (to_uid = ? OR to_uid IS NULL)
              AND read_at IS NULL
              AND from_uid != ?
            """,
            (now, uid, uid),
        )

    # Other sessions (active and stale — stale just means idle, not exited)
    others = db.execute(
        """
        SELECT uid, label, task, working_on, status, last_seen, cwd FROM sessions
        WHERE uid != ? AND status IN ('active', 'stale')
        ORDER BY last_seen DESC
        """,
        (uid,),
    ).fetchall()

    # Genuine local collisions: other active sessions that have claimed a file
    # THIS session has also claimed. File-claim overlap is the only high-signal
    # "we're stepping on each other" indicator — plain repo/dir co-tenancy isn't
    # (almost every session lives under ~/projects), so we don't surface that.
    my_files = {
        r["filepath"]
        for r in db.execute(
            "SELECT filepath FROM claims WHERE uid = ?", (uid,)
        ).fetchall()
    }
    collisions = {}  # other uid -> set(overlapping filepaths)
    if my_files:
        ph = ",".join("?" * len(my_files))
        for r in db.execute(
            f"""
            SELECT c.uid, c.filepath FROM claims c
            JOIN sessions s ON c.uid = s.uid
            WHERE c.uid != ? AND s.status = 'active'
              AND c.filepath IN ({ph})
            """,
            (uid, *my_files),
        ).fetchall():
            collisions.setdefault(r["uid"], set()).add(r["filepath"])

    # Phase-2 classify directive (decided while the DB is still open). Fire the
    # sub-agent classify directive once the session has a MEANINGFUL name and
    # lacks a CONFIDENT classification — and re-assert it each turn until one
    # lands, capped so an ignoring agent isn't nagged forever. The deliberate
    # sub-agent classify-self writes confidence 80 (>= CLASSIFY_CONF_FLOOR), which
    # stops the directive; the tick's low-confidence floor pick does NOT, so a
    # named session still gets upgraded. Generic 'session01' names are skipped
    # (no signal yet) — the tick floor covers them until they're renamed.
    cur_topic = (checkin_resp or {}).get("topic") if isinstance(checkin_resp, dict) else None
    cur_conf = (checkin_resp or {}).get("topic_confidence") or 0 if isinstance(checkin_resp, dict) else 0
    if auto_topic:  # heuristic tagged it THIS turn (not yet reflected in checkin)
        cur_topic, cur_conf = auto_topic, auto_conf or 0

    label = _get_session_label()
    descriptive = bool(label) and not (
        label.startswith("session") and label[len("session"):].isdigit()
    )
    show_tier2 = False
    # Only nag when the cloud is reachable (classify-self has somewhere to land);
    # offline/private sessions stay quiet and rely on the tick floor once back.
    if isinstance(checkin_resp, dict) and descriptive and cur_conf < CLASSIFY_CONF_FLOOR:
        row = db.execute(
            "SELECT classify_prompted FROM sessions WHERE uid = ?", (uid,)
        ).fetchone()
        nudges = (row["classify_prompted"] if row and row["classify_prompted"] else 0)
        if nudges < CLASSIFY_MAX_NUDGES:
            show_tier2 = True
            db.execute(
                "UPDATE sessions SET classify_prompted = ? WHERE uid = ?",
                (nudges + 1, uid),
            )

    db.commit()
    db.close()

    # Cross-machine layer (best-effort, silent on failure / privacy / offline).
    # Server fills repo/topic/files/pr from this session's stored state.
    list_resp = _cloud_list_peers(uid) or {}
    cloud_lines = _render_cloud_tiers(list_resp.get("tiers"))
    solved_lines = _render_solved(list_resp.get("solved"))

    if auto_topic:
        # Heuristic tagged the session this turn — push it to the cloud (tight
        # timeout so a slow cloud can't stall the prompt) as provisional, silent
        # coverage. The directive below (if shown) is what asks for a confident
        # domain+topic; we no longer surface the heuristic guess as a note.
        _cloud_classify_self(uid, auto_topic, confidence=auto_conf,
                             timeout=CLOUD_TIMEOUT)
    classify_lines = _build_classify_block(uid) if show_tier2 else []

    # Cross-machine inbox: drain pending messages (peer broadcasts + server
    # topic-alerts) and persist them to ~/.claustrum/inbox/<uid>.json. Gated on
    # a successful checkin so we don't pile a second timeout on top when the
    # cloud is down/slow.
    inbox_msgs = (_cloud_inbox_drain(uid) or []) if checkin_resp is not None else []
    _persist_inbox(uid, inbox_msgs)

    # Only output if there's something worth reporting (local OR cloud).
    if (not messages and not others and not cloud_lines and not solved_lines
            and not classify_lines and not inbox_msgs):
        if data.get("hook_event_name") == "BeforeAgent":
            print("{}")
        return

    parts = []
    n = len(others)
    parts.append(f"[Claustrum \u2014 {n} other session{'s' if n != 1 else ''}]")

    def _name(o):
        return _clean_label(o["label"]) if o["label"] else o["uid"][:12]

    # Genuine collisions first — the only place we spend extra tokens on detail,
    # because this is the one thing that actually needs the user's attention.
    if collisions:
        parts.append("")
        parts.append("  ⚠️  Collisions on files you've claimed:")
        for o in others:
            ov = collisions.get(o["uid"])
            if not ov:
                continue
            files = ", ".join(sorted(os.path.basename(f) for f in ov))
            line = f"      • {_name(o)}: {files}"
            if o["task"]:
                # first line of the task only, truncated — never the whole prompt
                line += f" — {o['task'].splitlines()[0][:80]}"
            parts.append(line)

    # Potential clash (softer than a file collision): other live sessions in
    # the SAME working directory — e.g. a shared worktree. One line + names, so
    # the agent can `claustrum show <name>` to inspect before stepping on them.
    if cwd:
        same_dir = [
            o for o in others
            if o["cwd"] == cwd and o["uid"] not in collisions
        ]
        if same_dir and len(same_dir) <= DISPLAY_CLASH_MAX:
            names = ", ".join(_name(o) for o in same_dir[:3])
            extra = f" +{len(same_dir) - 3} more" if len(same_dir) > 3 else ""
            parts.append("")
            parts.append(
                f"  · {len(same_dir)} other live session(s) in this directory: "
                f"{names}{extra}  — `claustrum show <name>` to inspect"
            )

    # Lightweight one-line-per-session summary: most-recent-first, recent only,
    # capped. No task / working_on text — that was the wall of tokens.
    recent = [o for o in others if (now - o["last_seen"]) <= DISPLAY_RECENT_SECONDS]
    shown = recent[:DISPLAY_MAX_SESSIONS]
    if shown:
        parts.append("")
        for o in shown:
            ago = _format_ago(now - o["last_seen"])
            # ⠂ = active (recent heartbeat), ⠐ = idle
            indicator = "⠂" if o["status"] == "active" else "⠐"
            parts.append(f"  {indicator} {_name(o)} ({ago})")
    hidden = n - len(shown)
    if hidden > 0:
        parts.append(
            f"  … and {hidden} more — `claustrum status` for the full list"
        )

    if cloud_lines:
        parts.append("")
        parts.extend(cloud_lines)

    if solved_lines:
        parts.append("")
        parts.extend(solved_lines)

    if messages:
        # File-change broadcasts (PostToolUse fires one per edit, to every
        # session) are the bulk of the noise \u2014 collapse them to a single line.
        # Real directed messages (info / breaking-change / etc.) stay verbatim.
        fc = [m for m in messages if m["type"] == "file-change"]
        real = [m for m in messages if m["type"] != "file-change"]
        if real:
            parts.append("")
            parts.append("Messages:")
            for m in real:
                sender = m["from_uid"][:12] if m["from_uid"] else "system"
                parts.append(f"  \u2022 [{m['type']}] {sender}: {m['body']}")
        if fc:
            bases = []
            for m in fc:
                body = m["body"] or ""
                path = body.split(" ", 1)[1] if " " in body else body
                bases.append(os.path.basename(path))
            distinct = sorted(set(bases))
            senders = len({m["from_uid"] for m in fc})
            shown_f = ", ".join(distinct[:3])
            more_f = f" +{len(distinct) - 3} more" if len(distinct) > 3 else ""
            parts.append("")
            parts.append(
                f"  \u00b7 {len(fc)} file edit(s) by {senders} other session(s): "
                f"{shown_f}{more_f}"
            )

    if inbox_msgs:
        parts.append("")
        parts.append("Cross-machine messages:")
        for m in inbox_msgs:
            sender = (m.get("from_uid") or "system")[:12]
            parts.append(
                f"  • [{m.get('type', 'info')}] {sender}: {m.get('body', '')}"
            )

    if classify_lines:
        parts.append("")
        parts.extend(classify_lines)

    output = "\n".join(parts)
    if output.strip():
        if data.get("hook_event_name") == "BeforeAgent":
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": "BeforeAgent",
                    "additionalContext": output
                }
            }))
        else:
            print(output)


def hook_pre_tool(_args):
    """PreToolUse — enforce file claims for Edit/Write."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    tool_name = data.get("tool_name", "")
    tool_input = data.get("tool_input", {})

    if tool_name not in ("Edit", "Write"):
        return

    filepath = tool_input.get("file_path", "")
    if not filepath:
        return

    db = get_db()
    now = time.time()

    _ensure_session(db, uid)

    # Check for conflicting claim
    conflict = db.execute(
        """
        SELECT c.uid, s.task FROM claims c
        JOIN sessions s ON c.uid = s.uid
        WHERE c.filepath = ? AND c.uid != ? AND s.status = 'active'
        """,
        (filepath, uid),
    ).fetchone()

    if conflict:
        db.close()
        task_info = f" (task: {conflict['task']})" if conflict["task"] else ""
        print(
            f"Claustrum: {filepath} is claimed by session "
            f"{conflict['uid'][:12]}{task_info}. "
            f"Coordinate before editing. Use: "
            f"claustrum send --uid <your-uid> --to {conflict['uid']} "
            f'--body "requesting access to {os.path.basename(filepath)}"',
            file=sys.stderr,
        )
        sys.exit(2)

    # Claim the file
    db.execute(
        "INSERT OR REPLACE INTO claims (filepath, uid, claimed_at) VALUES (?,?,?)",
        (filepath, uid, now),
    )
    db.commit()
    db.close()


def hook_post_tool(_args):
    """PostToolUse — broadcast file changes to other sessions."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    tool_name = data.get("tool_name", "")
    tool_input = data.get("tool_input", {})

    if tool_name not in ("Edit", "Write"):
        return

    filepath = tool_input.get("file_path", "")
    if not filepath:
        return

    db = get_db()
    now = time.time()

    # Only broadcast if someone else is listening
    others = db.execute(
        "SELECT COUNT(*) as cnt FROM sessions WHERE uid != ? AND status = 'active'",
        (uid,),
    ).fetchone()

    if others["cnt"] > 0:
        db.execute(
            """
            INSERT INTO messages (from_uid, to_uid, type, body, created_at)
            VALUES (?, NULL, 'file-change', ?, ?)
            """,
            (uid, f"Edited {filepath}", now),
        )

    db.commit()
    db.close()

    # Feed the cloud detail layer: repo-relative file (for cross-machine t1/t2
    # set overlap) plus pr_number (cached gh) + last_push_at (local git). This
    # is the activity-bearing path — the per-turn hook stays lean. Best-effort;
    # privacy gate honors CLAUSTRUM_PRIVATE / CLAUSTRUM_PUBLIC.
    target = os.path.dirname(filepath) or data.get("cwd") or os.getcwd()
    rel = _rel_to_repo(filepath, data.get("cwd"))
    repo, branch = _git_info(target)
    _cloud_update(
        uid,
        files_touched=[rel] if rel else None,
        pr_number=_get_pr_number(target, repo, branch),
        last_push_at=_git_last_push_at(target),
    )


def hook_start(_args):
    """SessionStart — register this session."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    cwd = data.get("cwd")

    db = get_db()
    now = time.time()
    _ensure_session(db, uid, cwd)
    # Reap ghosts from a prior boot / dead panes first, so the "N other active
    # session(s)" count a freshly-woken session reports is accurate.
    _reap_dead(db, now)
    db.commit()

    # Best-effort cloud announcement
    checkin_resp = _cloud_checkin(uid, cwd=cwd)

    others = db.execute(
        "SELECT COUNT(*) as cnt FROM sessions WHERE uid != ? AND status = 'active'",
        (uid,),
    ).fetchone()
    db.close()

    # On resume, summarise what changed in this session's repo/topic while it
    # was away (peers active, PRs finished, claims expired). Gated on a
    # successful checkin so a down cloud doesn't add a second timeout.
    notes = []
    if others["cnt"] > 0:
        notes.append(f"{others['cnt']} other active session(s).")
    if checkin_resp is not None:
        resume_note = _format_resume(_cloud_resume_check(uid))
        if resume_note:
            notes.append(resume_note)

    if notes:
        msg = "[Claustrum] Session registered. " + " ".join(notes)
        if data.get("hook_event_name") == "SessionStart":
            print(json.dumps({"systemMessage": msg}))
        else:
            print(msg)
    else:
        if data.get("hook_event_name") == "SessionStart":
            print("{}")


def hook_stop(_args):
    """SessionEnd — mark session done locally, release claims, and (if the work
    was substantive) auto-publish it to the cloud solved-archive.

    Auto-archive is GATED on an existing PR: a session with a PR is objective
    evidence real work happened, so we record it as solved with a derived
    resolution — without relying on the agent remembering `claustrum done`.
    Sessions with no PR (exploratory / abandoned) are NOT pushed to the
    archive, so the 'already solved' signal isn't flooded with noise. The agent
    can always record a richer resolution explicitly via `claustrum done
    --resolution`."""
    data = json.load(sys.stdin)
    uid = data.get("session_id", "unknown")
    cwd = data.get("cwd")

    db = get_db()
    now = time.time()
    db.execute(
        "UPDATE sessions SET status = 'done', last_seen = ? WHERE uid = ?",
        (now, uid),
    )
    db.execute("DELETE FROM claims WHERE uid = ?", (uid,))
    db.commit()
    db.close()

    # Best-effort cloud archive — only for PR-backed (substantive) work.
    # _cloud_update no-ops on private/offline; the dispatch wrapper swallows
    # any error so SessionEnd never fails.
    target = cwd or os.getcwd()
    repo, branch = _git_info(target)
    pr = _get_pr_number(target, repo, branch)
    if pr:
        _cloud_update(uid, status="done", resolution=f"closed with PR #{pr}")


# ---------------------------------------------------------------------------
# CLI commands  (invoked directly by user or by Claude via Bash tool)
# ---------------------------------------------------------------------------

def cmd_checkin(args):
    """Register or update a session."""
    db = get_db()
    now = time.time()
    # Capture liveness fields from the current environment (the agent runs this
    # in its own tmux pane). pid is left to the hook path, where the hook's
    # parent is the Claude process; a CLI invocation's parent is a transient
    # shell, so recording it would be misleading.
    host = _host()
    pane = os.environ.get("TMUX_PANE") or None
    boot = _boot_id()
    db.execute(
        """
        INSERT INTO sessions
            (uid, task, working_on, status, cwd, last_seen, started_at,
             host, tmux_pane, boot_id)
        VALUES (?, ?, ?, 'active', ?, ?, ?, ?, ?, ?)
        ON CONFLICT(uid) DO UPDATE SET
            task = COALESCE(?, task),
            working_on = COALESCE(?, working_on),
            status = 'active',
            cwd = COALESCE(?, cwd),
            last_seen = ?,
            host = COALESCE(?, host),
            tmux_pane = COALESCE(?, tmux_pane),
            boot_id = COALESCE(?, boot_id)
        """,
        (
            args.uid, args.task, args.files, args.cwd, now, now,
            host, pane, boot,
            args.task, args.files, args.cwd, now,
            host, pane, boot,
        ),
    )
    db.commit()
    db.close()
    print(f"Session {args.uid[:12]} checked in.")

    # Best-effort cloud write-through (silent on failure)
    checkin_resp = _cloud_checkin(
        args.uid,
        task=args.task,
        cwd=args.cwd,
        force_private=getattr(args, "private", False),
        timeout=CLOUD_TIMEOUT_INTERACTIVE,
    )

    # Mirror the cloud topic down locally, or auto-classify from the task/repo
    # if still untagged, so an explicit check-in also yields a locally-joinable
    # topic. Same code path as the per-prompt hook.
    auto_signal = " ".join(
        filter(None, [args.task, os.path.basename(args.cwd or "")])
    )
    db = get_db()
    auto_topic, auto_conf = _mirror_or_autoclassify(
        db, args.uid, checkin_resp, auto_signal
    )
    db.commit()
    db.close()
    if auto_topic:
        _cloud_classify_self(args.uid, auto_topic, confidence=auto_conf,
                             timeout=CLOUD_TIMEOUT_INTERACTIVE)
        print(f"Auto-classified as topic '{auto_topic}' "
              f"(heuristic, confidence {auto_conf}) — "
              f"run classify-self to correct if needed.")


def cmd_heartbeat(args):
    """Reconcile local sessions against live tmux state so the cloud board
    matches reality. Driven by the tmux status-bar singleton tick (every ~60s)
    and by `wa` on reattach (scoped via --tmux-session).

    The per-prompt hook only fires when the agent processes a turn, so without
    this a session whose tmux pane is alive but idle drifts to 'paused' in the
    cloud board, and a session you've *quit* lingers as 'active' until the
    cloud's 60-min stale timer ages it out. Three things happen here:

      • REFRESH — bump last_seen + cloud check-in for any active/stale row that's
        live (pane present AND its Claude pid still running).
      • REVIVE  — a 'done' row that's still live (e.g. swept to 'done' by a
        SessionEnd/save-state cascade but never really closed) is flipped back to
        'active'. A genuinely-finished 'done' session is untouched.
      • REAP    — on a FULL run (no --tmux-session), dead sessions are reaped via
        _reap_dead and pushed to the cloud as 'paused', so a quit session leaves
        the live board now instead of in an hour. Scoped reattach runs only
        refresh/revive, never reap.

    Liveness is the Claude PROCESS, not just the tmux pane: a pane outlives the
    Claude that ran in it (quit Claude, the shell/pane lingers), so a row is live
    only if its pane is present AND its recorded Claude pid is still running
    (boot-guarded). This is what reaps a quit-but-pane-lingers session and dedups
    a reused pane (the stale registration's old pid is dead). A false reap
    self-heals on the next tick. It still
    never *creates* rows for panes it's never seen — registration stays with the
    SessionStart/prompt hook (the tick has no session uid for an unknown pane).
    Silent and best-effort end to end."""
    db = get_db()
    now = time.time()
    host = _host()
    boot = _boot_id()
    live_panes = _live_tmux_panes()
    live_sessions = _live_tmux_sessions()
    pane_names = _pane_session_names()  # pane -> current tmux session name (renames)
    target = getattr(args, "tmux_session", None)

    # When scoping to one tmux session, match on its pane ids rather than its
    # name: stored labels are truncated (~50 chars), so a long session name
    # wouldn't compare equal. Pane ids are exact. Fall back to a label compare
    # for rows with no recorded pane (legacy) or if the tmux lookup fails.
    target_panes = None
    if target:
        try:
            r = subprocess.run(
                ["tmux", "list-panes", "-t", target, "-F", "#{pane_id}"],
                capture_output=True, text=True, timeout=2,
            )
            if r.returncode == 0:
                target_panes = {p.strip() for p in r.stdout.splitlines() if p.strip()}
        except Exception:
            target_panes = None

    # Include 'done' so a session whose pane is still alive is REVIVED — e.g. a
    # session swept to 'done' by a SessionEnd/save-state cascade but never
    # actually closed. The live-confirmation gate below only touches rows whose
    # pane is provably alive, so a genuinely-finished 'done' session (pane gone)
    # is left alone.
    rows = db.execute(
        "SELECT uid, label, task, cwd, host, tmux_pane, pid, boot_id FROM sessions "
        "WHERE status IN ('active', 'stale', 'done')"
    ).fetchall()

    refreshed = []
    for s in rows:
        # Local rows only (NULL host = legacy single-machine row, treat as local).
        if s["host"] and s["host"] != host:
            continue
        # Scope to the reattached tmux session when asked.
        if target:
            if target_panes is not None and s["tmux_pane"]:
                if s["tmux_pane"] not in target_panes:
                    continue
            elif _clean_label(s["label"] or "") != target:
                continue
        # Only refresh sessions we can confirm are alive, so a stale/ghost row
        # isn't bounced back to 'active'. Mirrors _reap_dead's ground truth:
        # pane first, then label-vs-live-tmux-sessions. If tmux is unavailable
        # (both None) we can't confirm — skip rather than guess.
        if s["tmux_pane"] and live_panes is not None:
            if s["tmux_pane"] not in live_panes:
                continue                                 # pane gone
            if not _pid_alive(s["pid"], s["boot_id"], boot):
                continue        # pane lingers but the Claude process has exited
        elif live_sessions is not None and s["label"]:
            if _clean_label(s["label"]) not in live_sessions:
                continue
        else:
            continue
        # Propagate a rename: a session renames its tmux session (-> slug) AFTER
        # check-in, so re-derive the label from the pane's CURRENT tmux session
        # name. Per-pane ground truth, not _get_session_label() (which would read
        # THIS heartbeat process's context and clobber every label to e.g.
        # "projects"). Only adopt a non-empty derived name that actually differs.
        new_label = s["label"]
        if pane_names and s["tmux_pane"] and s["tmux_pane"] in pane_names:
            derived = _clean_label(pane_names[s["tmux_pane"]])
            if derived and derived != new_label:
                new_label = derived
        db.execute(
            "UPDATE sessions SET last_seen = ?, status = 'active', label = ? WHERE uid = ?",
            (now, new_label, s["uid"]),
        )
        refreshed.append((s["uid"], new_label, s["task"], s["cwd"]))

    db.commit()

    # ADOPT orphan Claude panes (full heartbeat only): a live Claude session
    # whose claustrum row was lost (e.g. a cleanup cascade) and that hasn't
    # prompted since has no row, so it never shows. Register a pane-keyed
    # placeholder ('tmux-<host>-<pane>') from tmux/process ground truth so it
    # turns up without interaction; the prompt hook re-registers it under its
    # real uid later and the dedup pass below drops this placeholder.
    adopted = []
    if not target:
        agent_panes = _live_agent_panes()
        if agent_panes:
            have = {p for (p,) in db.execute(
                "SELECT tmux_pane FROM sessions "
                "WHERE status = 'active' AND tmux_pane IS NOT NULL"
            ).fetchall()}
            for pane, cpid in agent_panes.items():
                if pane in have:
                    continue
                label = (_clean_label(pane_names.get(pane, "")) if pane_names else "") or "session"
                uid = f"tmux-{host}-{pane}"
                db.execute(
                    "INSERT INTO sessions "
                    "(uid, label, status, last_seen, started_at, host, tmux_pane, pid, boot_id) "
                    "VALUES (?, ?, 'active', ?, ?, ?, ?, ?, ?) "
                    "ON CONFLICT(uid) DO UPDATE SET label=excluded.label, "
                    "status='active', last_seen=excluded.last_seen, "
                    "tmux_pane=excluded.tmux_pane, pid=excluded.pid, boot_id=excluded.boot_id",
                    (uid, label, now, now, host, pane, cpid, boot),
                )
                adopted.append((uid, label))
        db.commit()

    # DEDUP to one active row per pane (full run): a reused pane, or a
    # placeholder adopted above plus the real hook row, both go active. Keep one
    # — prefer a real (hook) uid over a 'tmux-' placeholder, else the most
    # recently seen — and reap the rest so each pane shows once.
    dups = []
    if not target:
        by_pane = {}
        for r2 in db.execute(
            "SELECT uid, tmux_pane, last_seen FROM sessions "
            "WHERE status = 'active' AND tmux_pane IS NOT NULL"
        ).fetchall():
            by_pane.setdefault(r2["tmux_pane"], []).append(r2)
        for pane, group in by_pane.items():
            if len(group) < 2:
                continue
            group.sort(key=lambda r2: (
                1 if str(r2["uid"]).startswith("tmux-") else 0,
                -(r2["last_seen"] or 0),
            ))
            for r2 in group[1:]:
                db.execute("UPDATE sessions SET status = 'dead' WHERE uid = ?", (r2["uid"],))
                db.execute("DELETE FROM claims WHERE uid = ?", (r2["uid"],))
                dups.append(r2["uid"])
        if dups:
            db.commit()

    # Reconcile membership (full heartbeat only — never on a scoped reattach):
    # reap sessions whose tmux pane is gone so a QUIT session leaves the board
    # promptly instead of waiting out the cloud's stale timer. _reap_dead marks
    # them 'dead' locally via the same tmux ground truth used above and returns
    # their uids; we then push status='paused' to the cloud so the live board
    # drops them now (they archive a day later like any paused row). A false reap
    # self-heals: the session re-registers 'active' on its next tick.
    reaped = [] if target else _reap_dead(db, now)
    if reaped:
        db.commit()
    db.close()

    # Cloud write-through (best-effort, silent on failure / privacy / offline).
    # Pass each session's STORED label — without it _cloud_checkin falls back to
    # _get_session_label(), which reads THIS process's context (cwd basename,
    # etc.), not the session's. A periodic heartbeat runs outside any session's
    # tmux pane, so that fallback would stamp every session with the heartbeat
    # process's cwd basename (e.g. "projects"), clobbering the real labels.
    # Check a session in and, if the cloud still has no topic for it, give it a
    # best-guess topic from its label. An idle/adopted session gets no agent turn
    # to run classify-self, so without this it stays topic-less and never
    # participates in claustrum's topic/repo collision search — the point of the
    # board. Uses the same cheap heuristic the prompt hook uses (low confidence,
    # so a later deliberate classify-self always supersedes it). Once the cloud
    # has a topic, the response carries it and we stop re-classifying.
    def _checkin_and_classify(uid, label, task=None, cwd=None):
        resp = _cloud_checkin(uid, task=task, cwd=cwd, label=label, timeout=CLOUD_TIMEOUT)
        # Coverage floor: the tick ALWAYS commits a topic for an untagged session
        # (floor=True never returns None), so orphan / adopted / never-named panes
        # still get a domain+topic on the board. The cloud derives the domain from
        # the topic; the named-turn sub-agent later upgrades this low-confidence
        # pick (hook_prompt re-prompts while confidence is below the floor).
        if isinstance(resp, dict) and not resp.get("topic") and resp.get("topic_required"):
            topic, conf = _auto_classify_topic(resp.get("taxonomy") or [], label, floor=True)
            if topic:
                _cloud_classify_self(uid, topic, confidence=conf, timeout=CLOUD_TIMEOUT)

    for uid, label, task, cwd in refreshed:
        _checkin_and_classify(uid, label, task=task, cwd=cwd)
    # Adopted orphan panes: same path so they appear AND get classified.
    for uid, label in adopted:
        _checkin_and_classify(uid, label)
    # Push reaped + deduped-away sessions off the live board (active -> paused).
    for uid in reaped + dups:
        _cloud_update(uid, status="paused", timeout=CLOUD_TIMEOUT)

    if refreshed or adopted or reaped or dups:
        parts = [f"refreshed {len(refreshed)}"]
        if adopted:
            parts.append(f"adopted {len(adopted)}")
        if reaped:
            parts.append(f"reaped {len(reaped)}")
        if dups:
            parts.append(f"deduped {len(dups)}")
        print("Heartbeat: " + ", ".join(parts) + " session(s).")
    else:
        print("Heartbeat: no live local sessions to refresh.")


def cmd_update(args):
    """Update session task or status."""
    db = get_db()
    now = time.time()

    updates = ["last_seen = ?"]
    params = [now]
    if args.task:
        updates.append("task = ?")
        params.append(args.task)
    if args.status:
        updates.append("status = ?")
        params.append(args.status)
    if args.files:
        updates.append("working_on = ?")
        params.append(args.files)

    params.append(args.uid)
    db.execute(
        f"UPDATE sessions SET {', '.join(updates)} WHERE uid = ?", params
    )
    db.commit()
    db.close()
    print(f"Session {args.uid[:12]} updated.")

    # Cloud detail layer. --files maps to the value-scrubbed `working_on` line.
    # Status is normalised to the server's enum (active|paused|done); anything
    # else is left for the local DB only.
    cloud_status = args.status if args.status in ("active", "paused", "done") else None
    _cloud_update(
        args.uid,
        task=args.task,
        working_on=args.files,
        status=cloud_status,
        force_private=getattr(args, "private", False),
        timeout=CLOUD_TIMEOUT_INTERACTIVE,
    )


def cmd_topics(_args):
    """Print the canonical topic taxonomy for a classifying SUB-AGENT to read.

    This exists so an untagged session can be classified without the taxonomy
    ever entering the main session's context: the parent agent spawns a
    sub-agent, the sub-agent runs `claustrum topics` (output lands here, in the
    sub-agent's throwaway context), picks the best fit, and runs classify-self.
    """
    topics = _cloud_topics()
    if topics is None:
        print(
            "Taxonomy unavailable (no CLAUSTRUM_CLOUD_URL, offline, or private "
            "mode). Propose one directly with:"
        )
        print('  claustrum propose-topic <uid> "<name>" "<short description>"')
        return
    if not topics:
        print("Taxonomy is empty. Mint the first topic with:")
        print('  claustrum propose-topic <uid> "<name>" "<short description>"')
        return
    print(f"Claustrum taxonomy ({len(topics)} topics) — pick the best fit:")
    for t in sorted(topics, key=lambda x: (x.get("domain") or "", x.get("name") or "")):
        name = t.get("name") or "?"
        desc = (t.get("description") or "").strip()
        parent = t.get("parent")
        domain = t.get("domain")
        dom = f"[{domain}] " if domain else ""
        suffix = f"  (variant of {parent})" if parent else ""
        print(f"  • {dom}{name}{' — ' + desc if desc else ''}{suffix}")
    print("\nThen tag the session:")
    print('  claustrum classify-self <uid> "<topic>"')
    print('Or, if none fit:  claustrum propose-topic <uid> "<name>" "<description>" --domain <domain>')


def cmd_classify_self(args):
    """Tag this session with a topic (emergent taxonomy) and surface who has
    worked on it before — the cross-machine 'someone's already on this' signal."""
    # Local mirror first — authoritative + offline-safe. This is what makes the
    # topic joinable by uid even when the cloud is unreachable, so we write it
    # regardless of the cloud round-trip below.
    domain = getattr(args, "domain", None)
    db = get_db()
    _set_local_topic(db, args.uid, args.topic, args.confidence, domain=domain)
    db.commit()
    db.close()

    resp = _cloud_classify_self(args.uid, args.topic, confidence=args.confidence,
                                domain=domain)
    if resp is None:
        print(
            "Cloud classify failed or suppressed (no CLAUSTRUM_CLOUD_URL, "
            "private mode, offline, or server error). Local topic mirror "
            "written; cross-machine dedup signal unavailable.",
            file=sys.stderr,
        )
        return

    resolved_domain = resp.get("domain") or domain
    dom_note = f" (domain: {resolved_domain})" if resolved_domain else ""
    print(f"Session {args.uid[:12]} classified as topic '{args.topic}'{dom_note}.")
    dedupe = resp.get("historical_dedupe") or {}
    peers = dedupe.get("active_peers") or []
    prs = dedupe.get("related_prs") or []
    if peers:
        print(f"\n{len(peers)} other session(s) on this topic:")
        for p in peers:
            who = _short_email(p.get("user_email"))
            where = p.get("repo") or "?"
            on = p.get("working_on") or "-"
            print(f"  • {who} ({p.get('machine','?')}) in {where}: {on}")
    if prs:
        print("\nRelated PRs on this topic:")
        for pr in prs:
            print(f"  • {pr.get('repo')}#{pr.get('pr_number')} ({_short_email(pr.get('user_email'))})")

    solved = [s for s in (dedupe.get("solved") or []) if str(s.get("resolution") or "").strip()]
    if solved:
        print("\n\U0001f5c2️  This may already have been SOLVED before:")
        for s in solved:
            print(f"  • {_format_solved_entry(s)}")

    if not peers and not prs and not solved:
        print("No prior sessions on this topic — you're first.")


def cmd_propose_topic(args):
    """Add a topic to the canonical taxonomy immediately, unless it's a near-
    duplicate of an existing one (then it maps to that — classify into the
    existing name). The topic lands in --domain (default 'general'; must already
    exist — propose-domain it first)."""
    resp = _cloud_propose_topic(
        args.uid, args.name, args.description, domain=getattr(args, "domain", None)
    )
    if resp is None:
        print(
            "Cloud propose failed or suppressed (no CLAUSTRUM_CLOUD_URL, "
            "private mode, offline, or server error). Nothing stored.",
            file=sys.stderr,
        )
        sys.exit(1)

    name = resp.get("name", args.name)
    dom = resp.get("domain")
    dom_flag = f' --domain "{dom}"' if dom else ""
    dom_note = f" (domain: {dom})" if dom else ""
    if resp.get("mapped_to"):
        print(
            f"'{args.name}' is a near-duplicate of existing topic "
            f"'{resp['mapped_to']}'{dom_note} — classify into that:\n"
            f"  claustrum classify-self {args.uid} \"{resp['mapped_to']}\"{dom_flag}"
        )
    else:
        verb = "Added topic" if resp.get("created") else "Topic already exists:"
        print(
            f"{verb} '{name}'{dom_note}. Classify into it:\n"
            f"  claustrum classify-self {args.uid} \"{name}\"{dom_flag}"
        )


def cmd_domains(_args):
    """Print the canonical domain taxonomy for a classifying SUB-AGENT to read.

    Mirror of cmd_topics: an untagged session is classified without the taxonomy
    entering the main context — the sub-agent runs `claustrum domains` + `claustrum
    topics`, picks the best-fit domain+topic (or proposes new ones), and classifies.
    """
    domains = _cloud_domains()
    if domains is None:
        print(
            "Domains unavailable (no CLAUSTRUM_CLOUD_URL, offline, or private "
            "mode). Propose one directly with:"
        )
        print('  claustrum propose-domain <uid> "<name>" "<short description>"')
        return
    if not domains:
        print("Domain taxonomy is empty. Mint the first domain with:")
        print('  claustrum propose-domain <uid> "<name>" "<short description>"')
        return
    print(f"Claustrum domains ({len(domains)}) — pick the best fit:")
    for d in sorted(domains, key=lambda x: (x.get("name") or "")):
        name = d.get("name") or "?"
        desc = (d.get("description") or "").strip()
        parent = d.get("parent")
